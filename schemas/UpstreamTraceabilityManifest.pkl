class Counts {
  total: Int
  covered: Int
  planned: Int
  tracked: Int
}

class TraceabilityEntry {
  source: String
  name: String
  kind: "test"|"benchmark"
  line: Int
  classification: String
  status: "covered"|"planned"|"tracked"
  profile: String?
  localTestSuites: Listing<String> = new Listing {}
  fileIssues: Listing<String> = new Listing {}
  rationale: String
}

repository: String
commit: String
generatedAt: String
counts: Counts
entries: Listing<TraceabilityEntry>
