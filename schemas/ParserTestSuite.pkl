class UpstreamReference {
  kind: "test"|"benchmark"|"issue"|"snapshot"|"artifact" = "test"
  repository: String
  source: String
  cases: Listing<String>
  issues: Listing<String> = new Listing {}
}

suite = "parser"

class Input {
  source: String
  comments: Boolean?
  parseMode: ("base"|"html"|"sfc")?
  whitespace: ("preserve"|"condense")?
  ns: ("HTML"|"SVG"|"MATH_ML")?
  nativeTags: Listing<String> = new Listing {}
  voidTags: Listing<String> = new Listing {}
  customElementTags: Listing<String> = new Listing {}
  preTags: Listing<String> = new Listing {}
  ignoreNewlineTags: Listing<String> = new Listing {}
  delimiters: Delimiters?
}

class Delimiters {
  start: String
  end: String
}

class PointerAssertion {
  pointer: String
  equals: String|Int|Boolean|Null
}

class Expectation {
  errorCount: Int
  ast: Listing<PointerAssertion> = new Listing {}
  errors: Listing<PointerAssertion> = new Listing {}
}

id: String
title: String
kind: "template-base-parse"|"template-dom-parse" = "template-base-parse"
summary: String
features: Listing<String>
profile: String?
upstream: Listing<UpstreamReference>
input: Input
expect: Expectation
