amends "../../../schemas/CompilerCase.pkl"

id = "compiler.script.define-options-basic"
title = "defineOptions merges user-declared component options into the emitted default export"
kind = "sfc-script-compile"
summary = "defineOptions must erase the macro call and lower the declared option object into the emitted component options wrapper."

features {
  "script-setup.defineOptions"
  "compiler.script"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__/compileScript/defineOptions.spec.ts"
    cases {
      "basic usage"
    }
  }
}

input {
  filename = "defineOptions.vue"
  sfc = #"""
    <script setup>
    defineOptions({ name: "FooApp" })
    </script>
    """#
  scriptOptions {
    id = "define-options-basic"
  }
}

expect {
  normalizedCode = #"""

    export default /*@__PURE__*/Object.assign({ name: "FooApp" }, {
      __name: 'defineOptions',
      setup(__props, { expose: __expose }) {
      __expose();



    const __returned__ = {  }
    Object.defineProperty(__returned__, '__isScriptSetup', { enumerable: false, value: true })
    return __returned__
    }

    })
    """#
}
