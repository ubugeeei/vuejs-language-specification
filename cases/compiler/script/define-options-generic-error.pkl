amends "../../../schemas/CompilerCase.pkl"

id = "compiler.script.define-options-generic-error"
title = "defineOptions rejects type arguments"
kind = "sfc-script-compile"
summary = "defineOptions is a value-level macro and must reject generic type arguments with the stable compiler-sfc diagnostic."

features {
  "script-setup.defineOptions"
  "compiler.script"
  "compiler.error"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__/compileScript/defineOptions.spec.ts"
    cases {
      "should emit an error with type generic"
    }
  }
}

input {
  filename = "DefineOptionsGenericError.vue"
  sfc = #"""
    <script setup lang="ts">
    defineOptions<{ name: "FooApp" }>()
    </script>
    """#
  scriptOptions {
    id = "define-options-generic-error"
  }
}

expect {
  error {
    name = "Error"
    message = #"""
      [@vue/compiler-sfc] defineOptions() cannot accept type arguments

      DefineOptionsGenericError.vue
      1  |  <script setup lang="ts">
         |                           ^
      2  |  defineOptions<{ name: "FooApp" }>()
         |  ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
      3  |  </script>
      """#
  }
}
