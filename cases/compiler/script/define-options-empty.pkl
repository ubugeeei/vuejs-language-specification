amends "../../../schemas/CompilerCase.pkl"

id = "compiler.script.define-options-empty"
title = "Empty defineOptions still lowers into a stable component options shell"
kind = "sfc-script-compile"
summary = "An empty defineOptions call must erase the macro and preserve the default export structure without injecting unrelated options."

features {
  "script-setup.defineOptions"
  "compiler.script"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__/compileScript/defineOptions.spec.ts"
    cases {
      "empty argument"
    }
  }
}

input {
  filename = "defineOptionsEmpty.vue"
  sfc = #"""
    <script setup>
    defineOptions()
    </script>
    """#
  scriptOptions {
    id = "define-options-empty"
  }
}

expect {
  normalizedCode = #"""

    export default {
      __name: 'defineOptionsEmpty',
      setup(__props, { expose: __expose }) {
      __expose();



    const __returned__ = {  }
    Object.defineProperty(__returned__, '__isScriptSetup', { enumerable: false, value: true })
    return __returned__
    }

    }
    """#
}
