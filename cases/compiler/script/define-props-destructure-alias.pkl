amends "../../../schemas/CompilerCase.pkl"

id = "compiler.script.define-props-destructure-alias"
title = "Reactive props destructure preserves alias semantics"
kind = "sfc-script-compile"
summary = "Aliased destructured props must rewrite aliased reads to the original prop slot while preserving non-aliased local identifiers."

features {
  "script-setup.defineProps"
  "script-setup.destructure"
  "compiler.script"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__/compileScript/definePropsDestructure.spec.ts"
    cases {
      "aliasing"
    }
  }
}

input {
  filename = "definePropsDestructureAlias.vue"
  sfc = #"""
    <script setup>
    const { foo: bar } = defineProps(["foo"])
    let x = foo
    let y = bar
    </script>
    <template>{{ foo + bar }}</template>
    """#
  scriptOptions {
    id = "define-props-destructure-alias"
    inlineTemplate = true
  }
}

expect {
  bindings {
    new BindingExpectation {
      name = "foo"
      kind = "props"
    }
    new BindingExpectation {
      name = "bar"
      kind = "props-aliased"
    }
    new BindingExpectation {
      name = "x"
      kind = "setup-let"
    }
    new BindingExpectation {
      name = "y"
      kind = "setup-let"
    }
  }
  normalizedCode = #"""
    import { toDisplayString as _toDisplayString } from "vue"


    export default {
      __name: 'definePropsDestructureAlias',
      props: ["foo"],
      setup(__props) {


    let x = foo
    let y = __props.foo

    return (_ctx, _cache) => {
      return _toDisplayString(__props.foo + __props.foo)
    }
    }

    }
    """#
}
