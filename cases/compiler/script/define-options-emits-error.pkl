amends "../../../schemas/CompilerCase.pkl"

id = "compiler.script.define-options-emits-error"
title = "defineOptions rejects emits declarations"
kind = "sfc-script-compile"
summary = "defineOptions must not be used to declare emits and must emit the stable compiler-sfc diagnostic that redirects the author to defineEmits."

features {
  "script-setup.defineOptions"
  "compiler.script"
  "compiler.error"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__/compileScript/defineOptions.spec.ts"
    cases {
      "should emit an error with props or emits property"
    }
  }
}

input {
  filename = "DefineOptionsEmitsError.vue"
  sfc = #"""
    <script setup>
    defineOptions({ emits: ["update"] })
    </script>
    """#
  scriptOptions {
    id = "define-options-emits-error"
  }
}

expect {
  error {
    name = "Error"
    message = #"""
      [@vue/compiler-sfc] defineOptions() cannot be used to declare emits. Use defineEmits() instead.

      DefineOptionsEmitsError.vue
      1  |  <script setup>
      2  |  defineOptions({ emits: ["update"] })
         |                  ^^^^^^^^^^^^^^^^^
      3  |  </script>
      """#
  }
}
