amends "../../../schemas/CompilerCase.pkl"

id = "compiler.script.define-emits-both-args-error"
title = "defineEmits rejects simultaneous type and runtime arguments"
kind = "sfc-script-compile"
summary = "defineEmits must reject programs that provide both type arguments and runtime arguments in the same macro call."

features {
  "script-setup.defineEmits"
  "compiler.script"
  "compiler.error"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__/compileScript/defineEmits.spec.ts"
    cases {
      "w/ both type and non-type args"
    }
  }
}

input {
  filename = "DefineEmitsBothError.vue"
  sfc = #"""
    <script setup lang="ts">
    defineEmits<{}>({})
    </script>
    """#
  scriptOptions {
    id = "define-emits-both-args-error"
  }
}

expect {
  error {
    name = "Error"
    message = #"""
      [@vue/compiler-sfc] defineEmits() cannot accept both type and non-type arguments at the same time. Use one or the other.

      DefineEmitsBothError.vue
      1  |  <script setup lang="ts">
         |                           ^
      2  |  defineEmits<{}>({})
         |  ^^^^^^^^^^^^^^^^^^^
      3  |  </script>
      """#
  }
}
