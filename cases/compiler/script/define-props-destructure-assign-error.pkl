amends "../../../schemas/CompilerCase.pkl"

id = "compiler.script.define-props-destructure-assign-error"
title = "defineProps destructure bindings remain readonly"
kind = "sfc-script-compile"
summary = "Reactive props destructure bindings must reject assignment because the destructured aliases remain readonly views of props."

features {
  "script-setup.defineProps"
  "script-setup.destructure"
  "compiler.script"
  "compiler.error"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__/compileScript/definePropsDestructure.spec.ts"
    cases {
      "should error if assignment to destructured prop binding"
    }
  }
}

input {
  filename = "DefinePropsDestructureAssignError.vue"
  sfc = #"""
    <script setup>
    const { foo } = defineProps(["foo"])
    foo = "bar"
    </script>
    """#
  scriptOptions {
    id = "define-props-destructure-assign-error"
  }
}

expect {
  error {
    name = "Error"
    message = #"""
      [@vue/compiler-sfc] Cannot assign to destructured props as they are readonly.

      DefinePropsDestructureAssignError.vue
      1  |  <script setup>
      2  |  const { foo } = defineProps(["foo"])
         |                                       ^
      3  |  foo = "bar"
         |  ^^^
      4  |  </script>
      """#
  }
}
