amends "../../../schemas/CompilerCase.pkl"

id = "compiler.style.global-selector"
title = "Scoped :global selectors bypass scope rewriting"
kind = "sfc-style-compile"
summary = "A :global selector must be emitted without the scoped attribute so the authored global selector remains globally visible."

features {
  "style.scoped"
  "style.global"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "playground/e2e/css-compile.test.ts"
    cases {
      "should handle :global() pseudo-selector"
    }
  }
}

input {
  filename = "GlobalSelector.vue"
  source = #"""
    :global(.theme-dark) .card { color: red; }
    """#
  styleOptions {
    id = "data-v-test"
    scoped = true
  }
}

expect {
  normalizedCode = ".theme-dark { color: red;\n}"
}
