amends "../../../schemas/CompilerCase.pkl"

id = "compiler.template.v-html-basic"
title = "v-html lowers to innerHTML patching semantics"
kind = "template-dom-compile"
summary = "v-html must compile to an innerHTML property write with the corresponding DOM patch flag."

features {
  "template.v-html"
  "compiler.dom"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-dom/__tests__/transforms/vHtml.spec.ts"
    cases {
      "should convert v-html to innerHTML"
    }
  }
}

input {
  source = #"""
    <div v-html="test"/>
    """#
  compilerOptions {
    mode = "module"
    prefixIdentifiers = true
  }
}

expect {
  helpers {
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
  }
  ast {
    new PointerAssertion {
      pointer = "/children/0/codegenNode/props/properties/0/key/content"
      equals = "innerHTML"
    }
    new PointerAssertion {
      pointer = "/children/0/codegenNode/props/properties/0/value/content"
      equals = "_ctx.test"
    }
    new PointerAssertion {
      pointer = "/children/0/codegenNode/patchFlag"
      equals = 8
    }
    new PointerAssertion {
      pointer = "/children/0/codegenNode/dynamicProps"
      equals = "[\"innerHTML\"]"
    }
  }
  normalizedCode = #"""
    import { openBlock as _openBlock, createElementBlock as _createElementBlock } from "vue"

    export function render(_ctx, _cache) {
      return (_openBlock(), _createElementBlock("div", { innerHTML: _ctx.test }, null, 8 /* PROPS */, ["innerHTML"]))
    }
    """#
}
