amends "../../../schemas/CompilerCase.pkl"

id = "compiler.template.v-bind-object-merge-props"
title = "v-bind object merges with explicit props in source order"
kind = "template-dom-compile"
summary = "A whole-object v-bind must compile into mergeProps while preserving authored static props and later explicit bindings in the correct merge order."

features {
  "template.v-bind"
  "compiler.props-merge"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-core/__tests__/transforms/transformElement.spec.ts"
    cases {
      "v-bind=\"obj\" after static prop"
      "FULL_PROPS (v-bind)"
    }
  }
  new UpstreamReference {
    kind = "snapshot"
    repository = "ubugeeei/vize"
    source = "tests/expected/vdom/v-bind.snap"
    cases {
      "v-bind object with dynamic"
    }
  }
}

input {
  source = #"""
    <button class="btn" v-bind="attrs" :disabled="busy" />
    """#
  compilerOptions {
    mode = "module"
    prefixIdentifiers = true
  }
}

expect {
  helpers {
    new HelperExpectation {
      name = "MERGE_PROPS"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
  }
  ast {
    new PointerAssertion {
      pointer = "/children/0/props/1/name"
      equals = "bind"
    }
    new PointerAssertion {
      pointer = "/children/0/props/1/exp/content"
      equals = "_ctx.attrs"
    }
    new PointerAssertion {
      pointer = "/children/0/props/2/arg/content"
      equals = "disabled"
    }
  }
  normalizedCode = #"""
    import { mergeProps as _mergeProps, openBlock as _openBlock, createElementBlock as _createElementBlock } from "vue"

    export function render(_ctx, _cache) {
      return (_openBlock(), _createElementBlock("button", _mergeProps({ class: "btn" }, _ctx.attrs, { disabled: _ctx.busy }), null, 16 /* FULL_PROPS */, ["disabled"]))
    }
    """#
}
