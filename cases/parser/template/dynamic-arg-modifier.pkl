amends "../../../schemas/ParserCase.pkl"

id = "parser.template.dynamic-arg-modifier"
title = "Dynamic directive arguments retain dynamicity and modifier metadata"
summary = "Directive parsing must preserve dynamic arguments as non-static simple expressions while retaining modifier names as static simple expressions."

features {
  "parser.directive"
  "parser.dynamic-argument"
  "parser.modifier"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-core/__tests__/parse.spec.ts"
    cases {
      "directive with dynamic argument and modifiers"
      "directive with a modifier"
    }
  }
  new UpstreamReference {
    kind = "snapshot"
    repository = "ubugeeei/vize"
    source = "tests/expected/parser/directive.snap"
    cases {
      "v-on with dynamic arg"
      "v-on with .once modifier"
    }
  }
}

input {
  source = #"""
    <button @[event].once="submit" />
    """#
}

expect {
  errorCount = 0
  ast {
    new PointerAssertion {
      pointer = "/children/0/props/0/name"
      equals = "on"
    }
    new PointerAssertion {
      pointer = "/children/0/props/0/arg/content"
      equals = "event"
    }
    new PointerAssertion {
      pointer = "/children/0/props/0/arg/constType"
      equals = "NOT_CONSTANT"
    }
    new PointerAssertion {
      pointer = "/children/0/props/0/modifiers/0/content"
      equals = "once"
    }
    new PointerAssertion {
      pointer = "/children/0/props/0/modifiers/0/constType"
      equals = "CAN_STRINGIFY"
    }
    new PointerAssertion {
      pointer = "/children/0/props/0/exp/content"
      equals = "submit"
    }
  }
}
