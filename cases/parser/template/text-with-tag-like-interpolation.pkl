amends "../../../schemas/ParserCase.pkl"

id = "parser.template.text-with-tag-like-interpolation"
title = "Interpolation expressions may contain tag-like operators"
summary = "Interpolation tokenization must not split on relational operators that resemble opening tags inside the JavaScript expression body."

features {
  "parser.interpolation"
  "parser.expression-boundary"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-core/__tests__/parse.spec.ts"
    cases {
      "text with interpolation which has `<`"
    }
  }
  new UpstreamReference {
    kind = "snapshot"
    repository = "ubugeeei/vize"
    source = "tests/expected/parser/interpolation.snap"
    cases {
      "interpolation with less than (tag-like)"
    }
  }
}

input {
  source = #"""
    <div>{{ a < b ? c : d }}</div>
    """#
}

expect {
  errorCount = 0
  ast {
    new PointerAssertion {
      pointer = "/children/0/children/0/type"
      equals = "INTERPOLATION"
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/content/content"
      equals = "a < b ? c : d"
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/content/constType"
      equals = "NOT_CONSTANT"
    }
  }
}
