amends "../../../schemas/TypeEvaluationCase.pkl"

id = "type-evaluation.props.define-model-basic"
title = "defineModel contributes model props and modifiers props to runtime props"
summary = "Type evaluation for defineModel must emit the main model prop and its modifiers companion prop with stable requiredness and constructor families."

features {
  "type-eval.defineModel"
  "type-eval.runtime-props"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__/compileScript/defineModel.spec.ts"
    cases {
      "basic usage"
    }
  }
  new UpstreamReference {
    repository = "vuejs/language-tools"
    source = "packages/component-meta/tests/index.spec.ts"
    cases {
      "reference-type-model"
    }
  }
}

input {
  filename = "DefineModel.vue"
  sfc = #"""
    <script setup lang="ts">
    const model = defineModel<string>({ required: true })
    </script>
    """#
  scriptOptions {
    id = "define-model-basic"
  }
}

expect {
  runtimeProps {
    new RuntimePropsExpectation {
      name = "modelValue"
      types {
        "String"
      }
      required = true
    }
    new RuntimePropsExpectation {
      name = "modelModifiers"
      required = false
    }
  }
  bindings {
    new BindingExpectation {
      name = "modelValue"
      kind = "props"
    }
    new BindingExpectation {
      name = "model"
      kind = "setup-ref"
    }
  }
}
