amends "../../../schemas/TypeEvaluationCase.pkl"

id = "type-evaluation.props.destructure-defaults"
title = "Reactive props destructure defaults preserve runtime prop metadata"
summary = "Default-bearing defineProps destructure must retain the same observable runtime constructor families and optionality as the underlying declared props."

features {
  "type-eval.defineProps"
  "type-eval.destructure"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__/compileScript/definePropsDestructure.spec.ts"
    cases {
      "default values w/ type declaration"
    }
  }
}

input {
  filename = "DestructureDefaults.vue"
  sfc = #"""
    <script setup lang="ts">
    const { foo = 1, bar = {}, func = () => {} } = defineProps<{
      foo?: number
      bar?: object
      func?: () => any
    }>()
    </script>
    """#
  scriptOptions {
    id = "destructure-defaults"
  }
}

expect {
  runtimeProps {
    new RuntimePropsExpectation {
      name = "foo"
      types {
        "Number"
      }
      required = false
    }
    new RuntimePropsExpectation {
      name = "bar"
      types {
        "Object"
      }
      required = false
    }
    new RuntimePropsExpectation {
      name = "func"
      types {
        "Function"
      }
      required = false
    }
  }
  bindings {
    new BindingExpectation {
      name = "foo"
      kind = "props"
    }
    new BindingExpectation {
      name = "bar"
      kind = "props"
    }
    new BindingExpectation {
      name = "func"
      kind = "props"
    }
  }
}
