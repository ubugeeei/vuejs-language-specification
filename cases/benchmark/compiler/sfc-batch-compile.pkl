amends "../../../schemas/BenchmarkCase.pkl"

id = "benchmark.compiler.sfc-batch-compile"
title = "Batch compile a mixed SFC corpus"
kind = "compiler-sfc-batch"
summary = "Measures end-to-end SFC parse, script compile, and template compile cost on a repeated mixed corpus."

features {
  "benchmark.compiler"
  "benchmark.sfc"
}

upstream {
  new UpstreamReference {
    kind = "artifact"
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__"
    cases {
      "compileScript"
      "compileTemplate"
    }
  }
  new UpstreamReference {
    kind = "artifact"
    repository = "ubugeeei/vize"
    source = "bench/run.ts"
    cases {
      "SFC Compile Benchmark"
    }
  }
}

input {
  fixtures {
    "fixtures/benchmarks/sfc/simple-card.vue"
    "fixtures/benchmarks/sfc/list-panel.vue"
    "fixtures/benchmarks/sfc/dashboard-shell.vue"
  }
  repeat = 40
}

measure {
  warmups = 1
  samples = 5
}
