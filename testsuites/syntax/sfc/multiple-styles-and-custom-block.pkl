amends "../../../schemas/SyntaxTestSuite.pkl"

id = "syntax.sfc.multiple-styles-and-custom-block"
title = "Descriptor preserves multiple style blocks and custom blocks"
summary = "SFC descriptor parsing must preserve every style block, their language and scoped flags, and retain custom blocks as first-class descriptor entries."

features {
  "sfc.style.multiple"
  "sfc.custom-block"
  "descriptor.style-lang"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__/parse.spec.ts"
    cases {
      "style block"
      "custom block"
    }
  }
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "playground/e2e/css-compile.test.ts"
    cases {
      "should compile SFC with multiple style blocks"
      "should handle style lang attribute"
    }
  }
}

input {
  filename = "DescriptorBlocks.vue"
  source = #"""
    <template>
      <article class="card">Body</article>
    </template>

    <style scoped lang="css">
    .card { color: red; }
    </style>

    <style lang="scss">
    .card { color: blue; }
    </style>

    <docs lang="md">
    # Card
    </docs>
    """#
}

expect {
  descriptor {
    template = true
    script = false
    scriptSetup = false
    styles = 2
    customBlocks = 1
    scriptLang = null
    scriptSetupLang = null
    styleLangs {
      "css"
      "scss"
    }
    scopedStyles = 1
  }
  templateContentIncludes {
    "class=\"card\""
    "Body"
  }
}
