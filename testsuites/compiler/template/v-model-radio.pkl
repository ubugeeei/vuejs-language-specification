amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.v-model-radio"
title = "Radio-input v-model lowers to vModelRadio"
kind = "template-dom-compile"
summary = "A radio input bound through v-model must lower to the vModelRadio runtime directive with an onUpdate:modelValue listener."

features {
  "template.v-model"
  "compiler.dom"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-dom/__tests__/transforms/vModel.spec.ts"
    cases {
      "simple expression for input (radio)"
    }
  }
}

input {
  source = #"""
    <input type="radio" v-model="model" />
    """#
  compilerOptions {
    mode = "module"
    prefixIdentifiers = true
  }
}

expect {
  helpers {
    new HelperExpectation {
      name = "V_MODEL_RADIO"
    }
    new HelperExpectation {
      name = "WITH_DIRECTIVES"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
  }
  normalizedCode = #"""
    import { vModelRadio as _vModelRadio, withDirectives as _withDirectives, openBlock as _openBlock, createElementBlock as _createElementBlock } from "vue"

    export function render(_ctx, _cache) {
      return _withDirectives((_openBlock(), _createElementBlock("input", {
        type: "radio",
        "onUpdate:modelValue": $event => ((_ctx.model) = $event)
      }, null, 8 /* PROPS */, ["onUpdate:modelValue"])), [
        [_vModelRadio, _ctx.model]
      ])
    }
    """#
}
