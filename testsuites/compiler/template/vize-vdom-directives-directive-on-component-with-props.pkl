amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-directives-directive-on-component-with-props"
title = "Imported template input: directive on component with props"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/directives.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.directives"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/directives.toml"
  source = "tests/fixtures/vdom/directives.toml"
  caseName = "directive on component with props"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/directives.toml"
    cases {
      "directive on component with props"
    }
  }
}

input {
  source = "<MyComponent v-focus :prop=\"value\" />"
}

expect {
  helpers {
    new HelperExpectation {
      name = "RESOLVE_COMPONENT"
    }
    new HelperExpectation {
      name = "RESOLVE_DIRECTIVE"
    }
    new HelperExpectation {
      name = "WITH_DIRECTIVES"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_BLOCK"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { resolveComponent: _resolveComponent, resolveDirective: _resolveDirective, withDirectives: _withDirectives, openBlock: _openBlock, createBlock: _createBlock } = _Vue
  
      const _component_MyComponent = _resolveComponent("MyComponent")
      const _directive_focus = _resolveDirective("focus")
  
      return _withDirectives((_openBlock(), _createBlock(_component_MyComponent, { prop: value }, null, 8 /* PROPS */, ["prop"])), [
        [_directive_focus]
      ])
    }
  }
  """#
}
