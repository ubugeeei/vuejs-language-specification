amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-transform-errors-v-bind-shorthand-with-dynamic-arg-and-no-expression"
title = "Imported transform input: v-bind shorthand with dynamic arg and no expression"
kind = "template-dom-compile"
summary = "Static compiler conformance derived from copied input tests/fixtures/errors/transform-errors.toml and the official vuejs/core compiler oracle, including exact diagnostics when emitted."

features {
  "compiler.template"
  "compiler.errors"
  "imported.input"
  "imported.input.transform-errors"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/errors/transform-errors.toml"
  source = "tests/fixtures/errors/transform-errors.toml"
  caseName = "v-bind shorthand with dynamic arg and no expression"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/errors/transform-errors.toml"
    cases {
      "v-bind shorthand with dynamic arg and no expression"
    }
  }
}

input {
  source = "<div :[dynamicKey]></div>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "NORMALIZE_PROPS"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
  }
  hoistCount = 0
  diagnostics {
    new ErrorExpectation {
      name = "SyntaxError"
      message = "v-bind with same-name shorthand only allows static argument."
      code = "X_V_BIND_INVALID_SAME_NAME_ARGUMENT"
    }
    new ErrorExpectation {
      name = "SyntaxError"
      message = "v-bind is missing expression."
      code = "X_V_BIND_NO_EXPRESSION"
    }
  }
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { normalizeProps: _normalizeProps, openBlock: _openBlock, createElementBlock: _createElementBlock } = _Vue
  
      return (_openBlock(), _createElementBlock("div", _normalizeProps({ [dynamicKey]: "" }), null, 16 /* FULL_PROPS */))
    }
  }
  """#
}
