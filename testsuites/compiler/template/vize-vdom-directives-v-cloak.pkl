amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-directives-v-cloak"
title = "Imported template input: v-cloak"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/directives.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.directives"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/directives.toml"
  source = "tests/fixtures/vdom/directives.toml"
  caseName = "v-cloak"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/directives.toml"
    cases {
      "v-cloak"
    }
  }
}

input {
  source = "<div v-cloak>{{ msg }}</div>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "TO_DISPLAY_STRING"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { toDisplayString: _toDisplayString, openBlock: _openBlock, createElementBlock: _createElementBlock } = _Vue
  
      return (_openBlock(), _createElementBlock("div", null, _toDisplayString(msg), 1 /* TEXT */))
    }
  }
  """#
}
