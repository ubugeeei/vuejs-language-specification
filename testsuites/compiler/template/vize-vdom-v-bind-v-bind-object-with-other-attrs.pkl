  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { mergeProps: _mergeProps, openBlock: _openBlock, createElementBlock: _createElementBlock } = _Vue
  
      return (_openBlock(), _createElementBlock("div", _mergeProps(attrs, { id: "static" }), null, 16 /* FULL_PROPS */))
    }
  }
  """#
}
