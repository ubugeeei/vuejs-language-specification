amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-component-v-bind-object-with-extra-props"
title = "Imported template input: v-bind object with extra props"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/component.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.component"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/component.toml"
  source = "tests/fixtures/vdom/component.toml"
  caseName = "v-bind object with extra props"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/component.toml"
    cases {
      "v-bind object with extra props"
    }
  }
}

input {
  source = "<MyComponent v-bind=\"props\" :extra=\"value\" />"
}

expect {
  helpers {
    new HelperExpectation {
      name = "RESOLVE_COMPONENT"
    }
    new HelperExpectation {
      name = "MERGE_PROPS"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_BLOCK"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { resolveComponent: _resolveComponent, mergeProps: _mergeProps, openBlock: _openBlock, createBlock: _createBlock } = _Vue
  
      const _component_MyComponent = _resolveComponent("MyComponent")
  
      return (_openBlock(), _createBlock(_component_MyComponent, _mergeProps(props, { extra: value }), null, 16 /* FULL_PROPS */, ["extra"]))
    }
  }
  """#
}
