amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vapor-v-bind-v-bind-camel"
title = "Imported vapor input: v-bind.camel"
kind = "template-expected-snapshot"
summary = "Provisional Vapor compiler conformance derived from copied input tests/fixtures/vapor/v-bind.toml. This suite remains snapshot-backed until an official vuejs/core Vapor oracle is vendored."

features {
  "compiler.template"
  "compiler.snapshot"
  "compiler.profile.vapor"
  "imported.input"
  "imported.input.vapor"
  "imported.input.v-bind"
}

profile = "vapor"

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vapor/v-bind.toml"
  source = "tests/fixtures/vapor/v-bind.toml"
  caseName = "v-bind.camel"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "minor/vapor compiler snapshot"
  operation = "copied snapshot oracle"
  profile = "vapor"
  provisional = true
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vapor/v-bind.toml"
    cases {
      "v-bind.camel"
    }
  }
}

input {
  source = "<svg :view-box.camel=\"viewBox\"></svg>"
}

expect {
  normalizedCode = #"""
  import { setAttr as _setAttr, renderEffect as _renderEffect, template as _template } from 'vue';
  const t0 = _template("<svg></svg>", true, 1)
  
  export function render(_ctx) {
    const n0 = t0()
    _renderEffect(() => _setAttr(n0, "viewBox", _ctx.viewBox, true))
    return n0
  }
  """#
  vendoredSnapshotOutput = #"""
  import { setAttr as _setAttr, renderEffect as _renderEffect, template as _template } from 'vue';
  const t0 = _template("<svg></svg>", true, 1)
  
  export function render(_ctx) {
    const n0 = t0()
    _renderEffect(() => _setAttr(n0, "viewBox", _ctx.viewBox, true))
    return n0
  }
  """#
  vendoredSnapshotOptions = "vapor"
}
