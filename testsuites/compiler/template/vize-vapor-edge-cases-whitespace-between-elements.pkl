amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vapor-edge-cases-whitespace-between-elements"
title = "Imported vapor input: whitespace between elements"
kind = "template-expected-snapshot"
summary = "Provisional Vapor compiler conformance derived from copied input tests/fixtures/vapor/edge-cases.toml. This suite remains snapshot-backed until an official vuejs/core Vapor oracle is vendored."

features {
  "compiler.template"
  "compiler.snapshot"
  "compiler.profile.vapor"
  "imported.input"
  "imported.input.vapor"
  "imported.input.edge-cases"
}

profile = "vapor"

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vapor/edge-cases.toml"
  source = "tests/fixtures/vapor/edge-cases.toml"
  caseName = "whitespace between elements"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "minor/vapor compiler snapshot"
  operation = "copied snapshot oracle"
  profile = "vapor"
  provisional = true
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vapor/edge-cases.toml"
    cases {
      "whitespace between elements"
    }
  }
}

input {
  source = "<span>Foo</span> <span>Bar</span>"
}

expect {
  normalizedCode = #"""
  import { template as _template } from 'vue';
  const t0 = _template("<span>Foo</span>")
  const t1 = _template(" ")
  const t2 = _template("<span>Bar</span>")
  
  export function render(_ctx) {
    const n0 = t0()
    const n1 = t1()
    const n2 = t2()
    return [n0, n1, n2]
  }
  """#
  vendoredSnapshotOutput = #"""
  import { template as _template } from 'vue';
  const t0 = _template("<span>Foo</span>")
  const t1 = _template(" ")
  const t2 = _template("<span>Bar</span>")
  
  export function render(_ctx) {
    const n0 = t0()
    const n1 = t1()
    const n2 = t2()
    return [n0, n1, n2]
  }
  """#
  vendoredSnapshotOptions = "vapor"
}
