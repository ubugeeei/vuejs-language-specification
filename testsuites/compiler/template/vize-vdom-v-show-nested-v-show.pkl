amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-v-show-nested-v-show"
title = "Imported template input: nested v-show"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/v-show.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.v-show"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/v-show.toml"
  source = "tests/fixtures/vdom/v-show.toml"
  caseName = "nested v-show"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/v-show.toml"
    cases {
      "nested v-show"
    }
  }
}

input {
  source = "<div v-show=\"outer\"><span v-show=\"inner\">nested</span></div>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "V_SHOW"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_VNODE"
    }
    new HelperExpectation {
      name = "WITH_DIRECTIVES"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { vShow: _vShow, createElementVNode: _createElementVNode, withDirectives: _withDirectives, openBlock: _openBlock, createElementBlock: _createElementBlock } = _Vue
  
      return _withDirectives((_openBlock(), _createElementBlock("div", null, [
        _withDirectives(_createElementVNode("span", null, "nested", 512 /* NEED_PATCH */), [
          [_vShow, inner]
        ])
      ], 512 /* NEED_PATCH */)), [
        [_vShow, outer]
      ])
    }
  }
  """#
}
