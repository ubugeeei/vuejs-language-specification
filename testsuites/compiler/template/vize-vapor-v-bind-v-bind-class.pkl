amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vapor-v-bind-v-bind-class"
title = "Imported vapor input: v-bind class"
kind = "template-expected-snapshot"
summary = "Provisional Vapor compiler conformance derived from copied input tests/fixtures/vapor/v-bind.toml. This suite remains snapshot-backed until an official vuejs/core Vapor oracle is vendored."

features {
  "compiler.template"
  "compiler.snapshot"
  "compiler.profile.vapor"
  "imported.input"
  "imported.input.vapor"
  "imported.input.v-bind"
}

profile = "vapor"

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vapor/v-bind.toml"
  source = "tests/fixtures/vapor/v-bind.toml"
  caseName = "v-bind class"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "minor/vapor compiler snapshot"
  operation = "copied snapshot oracle"
  profile = "vapor"
  provisional = true
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vapor/v-bind.toml"
    cases {
      "v-bind class"
    }
  }
}

input {
  source = "<div :class=\"cls\"></div>"
}

expect {
  normalizedCode = #"""
  import { setClass as _setClass, renderEffect as _renderEffect, template as _template } from 'vue';
  const t0 = _template("<div></div>", true)
  
  export function render(_ctx) {
    const n0 = t0()
    _renderEffect(() => _setClass(n0, _ctx.cls))
    return n0
  }
  """#
  vendoredSnapshotOutput = #"""
  import { setClass as _setClass, renderEffect as _renderEffect, template as _template } from 'vue';
  const t0 = _template("<div></div>", true)
  
  export function render(_ctx) {
    const n0 = t0()
    _renderEffect(() => _setClass(n0, _ctx.cls))
    return n0
  }
  """#
  vendoredSnapshotOptions = "vapor"
}
