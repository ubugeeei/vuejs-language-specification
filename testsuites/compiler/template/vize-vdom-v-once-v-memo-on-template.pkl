amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-v-once-v-memo-on-template"
title = "Imported template input: v-memo on template"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/v-once.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.v-once"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/v-once.toml"
  source = "tests/fixtures/vdom/v-once.toml"
  caseName = "v-memo on template"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/v-once.toml"
    cases {
      "v-memo on template"
    }
  }
}

input {
  source = "<template v-memo=\"[value]\"><div>A</div><div>B</div></template>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "CREATE_ELEMENT_VNODE"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
    new HelperExpectation {
      name = "WITH_MEMO"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { createElementVNode: _createElementVNode, openBlock: _openBlock, createElementBlock: _createElementBlock, withMemo: _withMemo } = _Vue
  
      return _withMemo([value], () => (_openBlock(), _createElementBlock("template", null, [
        _createElementVNode("div", null, "A"),
        _createElementVNode("div", null, "B")
      ])), _cache, 0)
    }
  }
  """#
}
