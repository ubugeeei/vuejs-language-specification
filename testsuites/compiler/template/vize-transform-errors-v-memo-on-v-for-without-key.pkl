amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-transform-errors-v-memo-on-v-for-without-key"
title = "Imported transform input: v-memo on v-for without key"
kind = "template-dom-compile"
summary = "Static compiler conformance derived from copied input tests/fixtures/errors/transform-errors.toml and the official vuejs/core compiler oracle, including exact diagnostics when emitted."

features {
  "compiler.template"
  "compiler.errors"
  "imported.input"
  "imported.input.transform-errors"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/errors/transform-errors.toml"
  source = "tests/fixtures/errors/transform-errors.toml"
  caseName = "v-memo on v-for without key"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/errors/transform-errors.toml"
    cases {
      "v-memo on v-for without key"
    }
  }
}

input {
  source = "<div v-for=\"item in items\" v-memo=\"[item]\"></div>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "RENDER_LIST"
    }
    new HelperExpectation {
      name = "FRAGMENT"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
    new HelperExpectation {
      name = "IS_MEMO_SAME"
    }
    new HelperExpectation {
      name = "WITH_MEMO"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { renderList: _renderList, Fragment: _Fragment, openBlock: _openBlock, createElementBlock: _createElementBlock, isMemoSame: _isMemoSame, withMemo: _withMemo } = _Vue
  
      return (_openBlock(true), _createElementBlock(_Fragment, null, _renderList(items, (item, __, ___, _cached) => {
        const _memo = ([item])
        if (_cached && _isMemoSame(_cached, _memo)) return _cached
        const _item = (_openBlock(), _createElementBlock("div"))
        _item.memo = _memo
        return _item
      }, _cache, 0), 256 /* UNKEYED_FRAGMENT */))
    }
  }
  """#
}
