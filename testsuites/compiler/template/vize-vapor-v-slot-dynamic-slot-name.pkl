amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vapor-v-slot-dynamic-slot-name"
title = "Imported vapor input: dynamic slot name"
kind = "template-expected-snapshot"
summary = "Provisional Vapor compiler conformance derived from copied input tests/fixtures/vapor/v-slot.toml. This suite remains snapshot-backed until an official vuejs/core Vapor oracle is vendored."

features {
  "compiler.template"
  "compiler.snapshot"
  "compiler.profile.vapor"
  "imported.input"
  "imported.input.vapor"
  "imported.input.v-slot"
}

profile = "vapor"

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vapor/v-slot.toml"
  source = "tests/fixtures/vapor/v-slot.toml"
  caseName = "dynamic slot name"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "minor/vapor compiler snapshot"
  operation = "copied snapshot oracle"
  profile = "vapor"
  provisional = true
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vapor/v-slot.toml"
    cases {
      "dynamic slot name"
    }
  }
}

input {
  source = "<MyComponent><template #[slotName]>content</template></MyComponent>"
}

expect {
  normalizedCode = #"""
  import { resolveComponent as _resolveComponent, createComponentWithFallback as _createComponentWithFallback, template as _template } from 'vue';
  const t0 = _template("content")
  
  export function render(_ctx) {
    const _component_MyComponent = _resolveComponent("MyComponent")
    const n2 = _createComponentWithFallback(_component_MyComponent, null, {
      $: [
        () => ({
          name: _ctx.slotName,
          fn: () => {
            const n0 = t0()
            return n0
          }
        })
      ]
    }, true)
    return n2
  }
  """#
  vendoredSnapshotOutput = #"""
  import { resolveComponent as _resolveComponent, createComponentWithFallback as _createComponentWithFallback, template as _template } from 'vue';
  const t0 = _template("content")
  
  export function render(_ctx) {
    const _component_MyComponent = _resolveComponent("MyComponent")
    const n2 = _createComponentWithFallback(_component_MyComponent, null, {
      $: [
        () => ({
          name: _ctx.slotName,
          fn: () => {
            const n0 = t0()
            return n0
          }
        })
      ]
    }, true)
    return n2
  }
  """#
  vendoredSnapshotOptions = "vapor"
}
