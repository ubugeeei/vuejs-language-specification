amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.v-once-cached-subtree"
title = "v-once caches the rendered subtree"
kind = "template-dom-compile"
summary = "A v-once subtree must compile into render-cache storage guarded by setBlockTracking so subsequent renders reuse the cached subtree."

features {
  "template.v-once"
  "compiler.cache"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-core/__tests__/codegen.spec.ts"
    cases {
      "CacheExpression w/ isVOnce: true"
    }
  }
  new UpstreamReference {
    kind = "snapshot"
    repository = "ubugeeei/vize"
    source = "tests/expected/vdom/v-once.snap"
    cases {
      "simple v-once"
    }
  }
}

input {
  source = #"""
    <div v-once><span>{{ msg }}</span></div>
    """#
  compilerOptions {
    mode = "module"
    prefixIdentifiers = true
    cacheHandlers = true
  }
}

expect {
  helpers {
    new HelperExpectation {
      name = "SET_BLOCK_TRACKING"
    }
    new HelperExpectation {
      name = "TO_DISPLAY_STRING"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_VNODE"
    }
  }
  normalizedCode = #"""
    import { setBlockTracking as _setBlockTracking, toDisplayString as _toDisplayString, createElementVNode as _createElementVNode } from "vue"

    export function render(_ctx, _cache) {
      return _cache[0] || (
        _setBlockTracking(-1, true),
        (_cache[0] = _createElementVNode("div", null, [
          _createElementVNode("span", null, _toDisplayString(_ctx.msg), 1 /* TEXT */)
        ])).cacheIndex = 0,
        _setBlockTracking(1),
        _cache[0]
      )
    }
    """#
}
