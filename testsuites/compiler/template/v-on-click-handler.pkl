amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.v-on-click-handler"
title = "v-on handlers become onX props with explicit patch flags"
kind = "template-dom-compile"
summary = "A simple v-on handler must remain observable in the AST and compile into an onClick prop with the correct dynamic patch flag set."

features {
  "template.v-on"
  "compiler.events"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-core/__tests__/transforms/vOn.spec.ts"
    cases {
      "basic"
    }
  }
  new UpstreamReference {
    kind = "snapshot"
    repository = "ubugeeei/vize"
    source = "tests/expected/vdom/v-on.snap"
    cases {
      "v-on shorthand"
    }
  }
}

input {
  source = #"""
    <button @click="inc">{{ count }}</button>
    """#
  compilerOptions {
    mode = "module"
    prefixIdentifiers = true
  }
}

expect {
  helpers {
    new HelperExpectation {
      name = "TO_DISPLAY_STRING"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
  }
  ast {
    new PointerAssertion {
      pointer = "/children/0/props/0/name"
      equals = "on"
    }
    new PointerAssertion {
      pointer = "/children/0/props/0/arg/content"
      equals = "click"
    }
    new PointerAssertion {
      pointer = "/children/0/props/0/exp/content"
      equals = "_ctx.inc"
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/content/content"
      equals = "_ctx.count"
    }
  }
  normalizedCode = #"""
    import { toDisplayString as _toDisplayString, openBlock as _openBlock, createElementBlock as _createElementBlock } from "vue"

    export function render(_ctx, _cache) {
      return (_openBlock(), _createElementBlock("button", { onClick: _ctx.inc }, _toDisplayString(_ctx.count), 9 /* TEXT, PROPS */, ["onClick"]))
    }
    """#
}
