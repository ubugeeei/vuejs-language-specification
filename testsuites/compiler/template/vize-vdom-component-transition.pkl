amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-component-transition"
title = "Imported template input: Transition"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/component.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.component"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/component.toml"
  source = "tests/fixtures/vdom/component.toml"
  caseName = "Transition"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/component.toml"
    cases {
      "Transition"
    }
  }
}

input {
  source = "<Transition name=\"fade\"><div v-if=\"show\">content</div></Transition>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_COMMENT"
    }
    new HelperExpectation {
      name = "TRANSITION"
    }
    new HelperExpectation {
      name = "WITH_CTX"
    }
    new HelperExpectation {
      name = "CREATE_BLOCK"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { openBlock: _openBlock, createElementBlock: _createElementBlock, createCommentVNode: _createCommentVNode, Transition: _Transition, withCtx: _withCtx, createBlock: _createBlock } = _Vue
  
      return (_openBlock(), _createBlock(_Transition, { name: "fade" }, {
        default: _withCtx(() => [
          show
            ? (_openBlock(), _createElementBlock("div", { key: 0 }, "content"))
            : _createCommentVNode("v-if", true)
        ]),
        _: 1 /* STABLE */
      }))
    }
  }
  """#
}
