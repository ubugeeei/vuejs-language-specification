amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-transform-errors-v-slot-duplicate-slot-names"
title = "Imported transform input: v-slot duplicate slot names"
kind = "template-dom-compile"
summary = "Static compiler conformance derived from copied input tests/fixtures/errors/transform-errors.toml and the official vuejs/core compiler oracle, including exact diagnostics when emitted."

features {
  "compiler.template"
  "compiler.errors"
  "imported.input"
  "imported.input.transform-errors"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/errors/transform-errors.toml"
  source = "tests/fixtures/errors/transform-errors.toml"
  caseName = "v-slot duplicate slot names"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/errors/transform-errors.toml"
    cases {
      "v-slot duplicate slot names"
    }
  }
}

input {
  source = "<Comp><template #foo></template><template #foo></template></Comp>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "RESOLVE_COMPONENT"
    }
    new HelperExpectation {
      name = "WITH_CTX"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_BLOCK"
    }
  }
  hoistCount = 0
  diagnostics {
    new ErrorExpectation {
      name = "SyntaxError"
      message = "Duplicate slot names found."
      code = "X_V_SLOT_DUPLICATE_SLOT_NAMES"
    }
  }
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { resolveComponent: _resolveComponent, withCtx: _withCtx, openBlock: _openBlock, createBlock: _createBlock } = _Vue
  
      const _component_Comp = _resolveComponent("Comp")
  
      return (_openBlock(), _createBlock(_component_Comp, null, {
        foo: _withCtx(() => []),
        _: 1 /* STABLE */
      }))
    }
  }
  """#
}
