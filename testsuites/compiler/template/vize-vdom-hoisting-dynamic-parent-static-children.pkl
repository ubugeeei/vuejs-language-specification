amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-hoisting-dynamic-parent-static-children"
title = "Imported template input: dynamic parent static children"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/hoisting.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.hoisting"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/hoisting.toml"
  source = "tests/fixtures/vdom/hoisting.toml"
  caseName = "dynamic parent static children"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/hoisting.toml"
    cases {
      "dynamic parent static children"
    }
  }
}

input {
  source = "<div :class=\"cls\"><span>a</span><span>b</span></div>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "CREATE_ELEMENT_VNODE"
    }
    new HelperExpectation {
      name = "NORMALIZE_CLASS"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { createElementVNode: _createElementVNode, normalizeClass: _normalizeClass, openBlock: _openBlock, createElementBlock: _createElementBlock } = _Vue
  
      return (_openBlock(), _createElementBlock("div", {
        class: _normalizeClass(cls)
      }, [
        _createElementVNode("span", null, "a"),
        _createElementVNode("span", null, "b")
      ], 2 /* CLASS */))
    }
  }
  """#
}
