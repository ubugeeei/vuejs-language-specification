amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-v-slot-suspense-slots"
title = "Imported template input: Suspense slots"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/v-slot.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.v-slot"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/v-slot.toml"
  source = "tests/fixtures/vdom/v-slot.toml"
  caseName = "Suspense slots"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/v-slot.toml"
    cases {
      "Suspense slots"
    }
  }
}

input {
  source = "<Suspense><template #default><AsyncComponent /></template><template #fallback>Loading...</template></Suspense>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "RESOLVE_COMPONENT"
    }
    new HelperExpectation {
      name = "CREATE_VNODE"
    }
    new HelperExpectation {
      name = "CREATE_TEXT"
    }
    new HelperExpectation {
      name = "SUSPENSE"
    }
    new HelperExpectation {
      name = "WITH_CTX"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_BLOCK"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { resolveComponent: _resolveComponent, createVNode: _createVNode, createTextVNode: _createTextVNode, Suspense: _Suspense, withCtx: _withCtx, openBlock: _openBlock, createBlock: _createBlock } = _Vue
  
      const _component_AsyncComponent = _resolveComponent("AsyncComponent")
  
      return (_openBlock(), _createBlock(_Suspense, null, {
        default: _withCtx(() => [
          _createVNode(_component_AsyncComponent)
        ]),
        fallback: _withCtx(() => [
          _createTextVNode("Loading...")
        ]),
        _: 1 /* STABLE */
      }))
    }
  }
  """#
}
