amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.v-model-textarea"
title = "Textarea v-model lowers to vModelText"
kind = "template-dom-compile"
summary = "A textarea bound through v-model must lower to the vModelText runtime directive and an onUpdate:modelValue listener."

features {
  "template.v-model"
  "compiler.dom"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-dom/__tests__/transforms/vModel.spec.ts"
    cases {
      "simple expression for textarea"
    }
  }
}

input {
  source = #"""
    <textarea v-model="model" />
    """#
  compilerOptions {
    mode = "module"
    prefixIdentifiers = true
  }
}

expect {
  helpers {
    new HelperExpectation {
      name = "V_MODEL_TEXT"
    }
    new HelperExpectation {
      name = "WITH_DIRECTIVES"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
  }
  normalizedCode = #"""
    import { vModelText as _vModelText, withDirectives as _withDirectives, openBlock as _openBlock, createElementBlock as _createElementBlock } from "vue"

    export function render(_ctx, _cache) {
      return _withDirectives((_openBlock(), _createElementBlock("textarea", {
        "onUpdate:modelValue": $event => ((_ctx.model) = $event)
      }, null, 8 /* PROPS */, ["onUpdate:modelValue"])), [
        [_vModelText, _ctx.model]
      ])
    }
    """#
}
