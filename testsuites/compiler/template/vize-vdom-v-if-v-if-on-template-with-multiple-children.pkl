amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-v-if-v-if-on-template-with-multiple-children"
title = "Imported template input: v-if on template with multiple children"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/v-if.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.v-if"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/v-if.toml"
  source = "tests/fixtures/vdom/v-if.toml"
  caseName = "v-if on template with multiple children"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/v-if.toml"
    cases {
      "v-if on template with multiple children"
    }
  }
}

input {
  source = "<template v-if=\"show\"><span>1</span><span>2</span><span>3</span></template>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "CREATE_ELEMENT_VNODE"
    }
    new HelperExpectation {
      name = "FRAGMENT"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_COMMENT"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { createElementVNode: _createElementVNode, Fragment: _Fragment, openBlock: _openBlock, createElementBlock: _createElementBlock, createCommentVNode: _createCommentVNode } = _Vue
  
      return show
        ? (_openBlock(), _createElementBlock(_Fragment, { key: 0 }, [
            _createElementVNode("span", null, "1"),
            _createElementVNode("span", null, "2"),
            _createElementVNode("span", null, "3")
          ], 64 /* STABLE_FRAGMENT */))
        : _createCommentVNode("v-if", true)
    }
  }
  """#
}
