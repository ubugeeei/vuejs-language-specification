amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-v-on-dynamic-event-with-modifier"
title = "Imported template input: dynamic event with modifier"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/v-on.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.v-on"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/v-on.toml"
  source = "tests/fixtures/vdom/v-on.toml"
  caseName = "dynamic event with modifier"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/v-on.toml"
    cases {
      "dynamic event with modifier"
    }
  }
}

input {
  source = "<button @[event].stop=\"handler\"></button>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "TO_HANDLER_KEY"
    }
    new HelperExpectation {
      name = "V_ON_WITH_MODIFIERS"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { toHandlerKey: _toHandlerKey, withModifiers: _withModifiers, openBlock: _openBlock, createElementBlock: _createElementBlock } = _Vue
  
      return (_openBlock(), _createElementBlock("button", {
        [_toHandlerKey(event)]: _withModifiers(handler, ["stop"])
      }, null, 16 /* FULL_PROPS */))
    }
  }
  """#
}
