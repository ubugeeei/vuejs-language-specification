amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-transform-errors-keepalive-with-multiple-children"
title = "Imported transform input: KeepAlive with multiple children"
kind = "template-dom-compile"
summary = "Static compiler conformance derived from copied input tests/fixtures/errors/transform-errors.toml and the official vuejs/core compiler oracle, including exact diagnostics when emitted."

features {
  "compiler.template"
  "compiler.errors"
  "imported.input"
  "imported.input.transform-errors"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/errors/transform-errors.toml"
  source = "tests/fixtures/errors/transform-errors.toml"
  caseName = "KeepAlive with multiple children"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/errors/transform-errors.toml"
    cases {
      "KeepAlive with multiple children"
    }
  }
}

input {
  source = "<KeepAlive><div></div><span></span></KeepAlive>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "CREATE_ELEMENT_VNODE"
    }
    new HelperExpectation {
      name = "KEEP_ALIVE"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_BLOCK"
    }
  }
  hoistCount = 0
  diagnostics {
    new ErrorExpectation {
      name = "SyntaxError"
      message = "<KeepAlive> expects exactly one child component."
      code = "X_KEEP_ALIVE_INVALID_CHILDREN"
    }
  }
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { createElementVNode: _createElementVNode, KeepAlive: _KeepAlive, openBlock: _openBlock, createBlock: _createBlock } = _Vue
  
      return (_openBlock(), _createBlock(_KeepAlive, null, [
        _createElementVNode("div"),
        _createElementVNode("span")
      ], 1024 /* DYNAMIC_SLOTS */))
    }
  }
  """#
}
