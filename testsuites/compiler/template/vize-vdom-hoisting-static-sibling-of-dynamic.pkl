amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-hoisting-static-sibling-of-dynamic"
title = "Imported template input: static sibling of dynamic"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/hoisting.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.hoisting"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/hoisting.toml"
  source = "tests/fixtures/vdom/hoisting.toml"
  caseName = "static sibling of dynamic"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/hoisting.toml"
    cases {
      "static sibling of dynamic"
    }
  }
}

input {
  source = "<div><span>static</span><span>{{ dynamic }}</span></div>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "CREATE_ELEMENT_VNODE"
    }
    new HelperExpectation {
      name = "TO_DISPLAY_STRING"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { createElementVNode: _createElementVNode, toDisplayString: _toDisplayString, openBlock: _openBlock, createElementBlock: _createElementBlock } = _Vue
  
      return (_openBlock(), _createElementBlock("div", null, [
        _createElementVNode("span", null, "static"),
        _createElementVNode("span", null, _toDisplayString(dynamic), 1 /* TEXT */)
      ]))
    }
  }
  """#
}
