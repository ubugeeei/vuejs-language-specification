amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-v-if-v-if-with-ternary-in-content"
title = "Imported template input: v-if with ternary in content"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/v-if.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.v-if"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/v-if.toml"
  source = "tests/fixtures/vdom/v-if.toml"
  caseName = "v-if with ternary in content"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/v-if.toml"
    cases {
      "v-if with ternary in content"
    }
  }
}

input {
  source = "<div v-if=\"show\">{{ ok ? \"yes\" : \"no\" }}</div>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "TO_DISPLAY_STRING"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_COMMENT"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { toDisplayString: _toDisplayString, openBlock: _openBlock, createElementBlock: _createElementBlock, createCommentVNode: _createCommentVNode } = _Vue
  
      return show
        ? (_openBlock(), _createElementBlock("div", { key: 0 }, _toDisplayString(ok ? "yes" : "no"), 1 /* TEXT */))
        : _createCommentVNode("v-if", true)
    }
  }
  """#
}
