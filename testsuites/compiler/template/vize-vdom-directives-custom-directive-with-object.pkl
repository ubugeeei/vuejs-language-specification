amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-directives-custom-directive-with-object"
title = "Imported template input: custom directive with object"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/directives.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.directives"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/directives.toml"
  source = "tests/fixtures/vdom/directives.toml"
  caseName = "custom directive with object"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/directives.toml"
    cases {
      "custom directive with object"
    }
  }
}

input {
  source = "<div v-pin=\"{ top: 10, left: 20 }\"></div>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "RESOLVE_DIRECTIVE"
    }
    new HelperExpectation {
      name = "WITH_DIRECTIVES"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { resolveDirective: _resolveDirective, withDirectives: _withDirectives, openBlock: _openBlock, createElementBlock: _createElementBlock } = _Vue
  
      const _directive_pin = _resolveDirective("pin")
  
      return _withDirectives((_openBlock(), _createElementBlock("div", null, null, 512 /* NEED_PATCH */)), [
        [_directive_pin, { top: 10, left: 20 }]
      ])
    }
  }
  """#
}
