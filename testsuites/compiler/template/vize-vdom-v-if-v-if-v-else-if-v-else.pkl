amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-v-if-v-if-v-else-if-v-else"
title = "Imported template input: v-if/v-else-if/v-else"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/v-if.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.v-if"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/v-if.toml"
  source = "tests/fixtures/vdom/v-if.toml"
  caseName = "v-if/v-else-if/v-else"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/v-if.toml"
    cases {
      "v-if/v-else-if/v-else"
    }
  }
}

input {
  source = "<div v-if=\"a\">A</div><div v-else-if=\"b\">B</div><div v-else>C</div>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_COMMENT"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { openBlock: _openBlock, createElementBlock: _createElementBlock, createCommentVNode: _createCommentVNode } = _Vue
  
      return a
        ? (_openBlock(), _createElementBlock("div", { key: 0 }, "A"))
        : b
          ? (_openBlock(), _createElementBlock("div", { key: 1 }, "B"))
          : (_openBlock(), _createElementBlock("div", { key: 2 }, "C"))
    }
  }
  """#
}
