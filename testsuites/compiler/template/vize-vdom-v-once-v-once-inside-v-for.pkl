amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-v-once-v-once-inside-v-for"
title = "Imported template input: v-once inside v-for"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/v-once.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.v-once"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/v-once.toml"
  source = "tests/fixtures/vdom/v-once.toml"
  caseName = "v-once inside v-for"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/v-once.toml"
    cases {
      "v-once inside v-for"
    }
  }
}

input {
  source = "<div v-for=\"item in items\" :key=\"item.id\"><span v-once>{{ item.static }}</span></div>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "RENDER_LIST"
    }
    new HelperExpectation {
      name = "FRAGMENT"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
    new HelperExpectation {
      name = "SET_BLOCK_TRACKING"
    }
    new HelperExpectation {
      name = "TO_DISPLAY_STRING"
    }
    new HelperExpectation {
      name = "CREATE_TEXT"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_VNODE"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { renderList: _renderList, Fragment: _Fragment, openBlock: _openBlock, createElementBlock: _createElementBlock, setBlockTracking: _setBlockTracking, toDisplayString: _toDisplayString, createTextVNode: _createTextVNode, createElementVNode: _createElementVNode } = _Vue
  
      return (_openBlock(true), _createElementBlock(_Fragment, null, _renderList(items, (item) => {
        return (_openBlock(), _createElementBlock("div", { key: item.id }, [
          _cache[0] || (
            _setBlockTracking(-1, true),
            (_cache[0] = _createElementVNode("span", null, [
              _createTextVNode(_toDisplayString(item.static), 1 /* TEXT */)
            ])).cacheIndex = 0,
            _setBlockTracking(1),
            _cache[0]
          )
        ]))
      }), 128 /* KEYED_FRAGMENT */))
    }
  }
  """#
}
