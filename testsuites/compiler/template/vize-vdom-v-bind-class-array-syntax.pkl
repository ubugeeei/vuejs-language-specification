amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-v-bind-class-array-syntax"
title = "Imported template input: class array syntax"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/v-bind.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.v-bind"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/v-bind.toml"
  source = "tests/fixtures/vdom/v-bind.toml"
  caseName = "class array syntax"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/v-bind.toml"
    cases {
      "class array syntax"
    }
  }
}

input {
  source = "<div :class=\"[activeClass, errorClass]\"></div>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "NORMALIZE_CLASS"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { normalizeClass: _normalizeClass, openBlock: _openBlock, createElementBlock: _createElementBlock } = _Vue
  
      return (_openBlock(), _createElementBlock("div", {
        class: _normalizeClass([activeClass, errorClass])
      }, null, 2 /* CLASS */))
    }
  }
  """#
}
