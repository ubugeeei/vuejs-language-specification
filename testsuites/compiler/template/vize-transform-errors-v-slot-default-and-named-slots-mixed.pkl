amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-transform-errors-v-slot-default-and-named-slots-mixed"
title = "Imported transform input: v-slot default and named slots mixed"
kind = "template-dom-compile"
summary = "Static compiler conformance derived from copied input tests/fixtures/errors/transform-errors.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "compiler.errors"
  "imported.input"
  "imported.input.transform-errors"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/errors/transform-errors.toml"
  source = "tests/fixtures/errors/transform-errors.toml"
  caseName = "v-slot default and named slots mixed"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/errors/transform-errors.toml"
    cases {
      "v-slot default and named slots mixed"
    }
  }
}

input {
  source = "<Comp v-slot>text<template #header></template></Comp>"
}

expect {
  error = new ErrorExpectation {
    name = "SyntaxError"
    message = "Mixed v-slot usage on both the component and nested <template>. When there are multiple named slots, all slots should use <template> syntax to avoid scope ambiguity."
    code = "X_V_SLOT_MIXED_SLOT_USAGE"
  }
}
