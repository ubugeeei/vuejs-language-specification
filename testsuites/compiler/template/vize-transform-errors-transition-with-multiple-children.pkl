amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-transform-errors-transition-with-multiple-children"
title = "Imported transform input: Transition with multiple children"
kind = "template-dom-compile"
summary = "Static compiler conformance derived from copied input tests/fixtures/errors/transform-errors.toml and the official vuejs/core compiler oracle, including exact diagnostics when emitted."

features {
  "compiler.template"
  "compiler.errors"
  "imported.input"
  "imported.input.transform-errors"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/errors/transform-errors.toml"
  source = "tests/fixtures/errors/transform-errors.toml"
  caseName = "Transition with multiple children"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/errors/transform-errors.toml"
    cases {
      "Transition with multiple children"
    }
  }
}

input {
  source = "<Transition><div></div><span></span></Transition>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "CREATE_ELEMENT_VNODE"
    }
    new HelperExpectation {
      name = "TRANSITION"
    }
    new HelperExpectation {
      name = "WITH_CTX"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_BLOCK"
    }
  }
  hoistCount = 0
  diagnostics {
    new ErrorExpectation {
      name = "SyntaxError"
      message = "<Transition> expects exactly one child element or component."
      code = "X_TRANSITION_INVALID_CHILDREN"
    }
  }
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { createElementVNode: _createElementVNode, Transition: _Transition, withCtx: _withCtx, openBlock: _openBlock, createBlock: _createBlock } = _Vue
  
      return (_openBlock(), _createBlock(_Transition, null, {
        default: _withCtx(() => [
          _createElementVNode("div"),
          _createElementVNode("span")
        ]),
        _: 1 /* STABLE */
      }))
    }
  }
  """#
}
