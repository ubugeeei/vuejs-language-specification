amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-v-bind-v-bind-is"
title = "Imported template input: v-bind is"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/v-bind.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.v-bind"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/v-bind.toml"
  source = "tests/fixtures/vdom/v-bind.toml"
  caseName = "v-bind is"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/v-bind.toml"
    cases {
      "v-bind is"
    }
  }
}

input {
  source = "<component :is=\"comp\"></component>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "RESOLVE_DYNAMIC_COMPONENT"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_BLOCK"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { resolveDynamicComponent: _resolveDynamicComponent, openBlock: _openBlock, createBlock: _createBlock } = _Vue
  
      return (_openBlock(), _createBlock(_resolveDynamicComponent(comp)))
    }
  }
  """#
}
