amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-v-model-component-named-v-model-with-modifier"
title = "Imported template input: component named v-model with modifier"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/v-model.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.v-model"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/v-model.toml"
  source = "tests/fixtures/vdom/v-model.toml"
  caseName = "component named v-model with modifier"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/v-model.toml"
    cases {
      "component named v-model with modifier"
    }
  }
}

input {
  source = "<MyComponent v-model:title.capitalize=\"pageTitle\" />"
}

expect {
  helpers {
    new HelperExpectation {
      name = "RESOLVE_COMPONENT"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_BLOCK"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { resolveComponent: _resolveComponent, openBlock: _openBlock, createBlock: _createBlock } = _Vue
  
      const _component_MyComponent = _resolveComponent("MyComponent")
  
      return (_openBlock(), _createBlock(_component_MyComponent, {
        title: pageTitle,
        "onUpdate:title": $event => ((pageTitle) = $event),
        titleModifiers: { capitalize: true }
      }, null, 8 /* PROPS */, ["title", "onUpdate:title"]))
    }
  }
  """#
}
