amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-v-once-v-memo-on-component"
title = "Imported template input: v-memo on component"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/v-once.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.v-once"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/v-once.toml"
  source = "tests/fixtures/vdom/v-once.toml"
  caseName = "v-memo on component"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/v-once.toml"
    cases {
      "v-memo on component"
    }
  }
}

input {
  source = "<MyComponent v-memo=\"[prop]\" :prop=\"prop\" />"
}

expect {
  helpers {
    new HelperExpectation {
      name = "RESOLVE_COMPONENT"
    }
    new HelperExpectation {
      name = "CREATE_VNODE"
    }
    new HelperExpectation {
      name = "WITH_MEMO"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { resolveComponent: _resolveComponent, createVNode: _createVNode, withMemo: _withMemo } = _Vue
  
      const _component_MyComponent = _resolveComponent("MyComponent")
  
      return _withMemo([prop], () => _createVNode(_component_MyComponent, { prop: prop }, null, 8 /* PROPS */, ["prop"]), _cache, 0)
    }
  }
  """#
}
