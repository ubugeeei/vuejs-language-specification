  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { renderList: _renderList, Fragment: _Fragment, openBlock: _openBlock, createElementBlock: _createElementBlock, toDisplayString: _toDisplayString, TransitionGroup: _TransitionGroup, withCtx: _withCtx, createBlock: _createBlock } = _Vue
  
      return (_openBlock(), _createBlock(_TransitionGroup, { tag: "ul" }, {
        default: _withCtx(() => [
          (_openBlock(true), _createElementBlock(_Fragment, null, _renderList(items, (item) => {
            return (_openBlock(), _createElementBlock("li", { key: item }, _toDisplayString(item), 1 /* TEXT */))
          }), 128 /* KEYED_FRAGMENT */))
        ]),
