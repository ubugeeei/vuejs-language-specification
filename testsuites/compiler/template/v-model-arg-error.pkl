amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.v-model-arg-error"
title = "Plain-element v-model rejects arguments"
kind = "template-dom-compile"
summary = "A v-model argument on a plain DOM element must be rejected with the stable compiler-dom diagnostic code."

features {
  "template.v-model"
  "compiler.dom"
  "compiler.error"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-dom/__tests__/transforms/vModel.spec.ts"
    cases {
      "plain elements with argument"
    }
  }
}

input {
  source = #"""
    <input v-model:value="model" />
    """#
  compilerOptions {
    mode = "module"
    prefixIdentifiers = true
  }
}

expect {
  error {
    name = "SyntaxError"
    message = "v-model argument is not supported on plain elements."
    code = "X_V_MODEL_ARG_ON_ELEMENT"
  }
}
