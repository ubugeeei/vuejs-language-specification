amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-v-once-basic-v-memo"
title = "Imported template input: basic v-memo"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/v-once.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.v-once"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/v-once.toml"
  source = "tests/fixtures/vdom/v-once.toml"
  caseName = "basic v-memo"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/v-once.toml"
    cases {
      "basic v-memo"
    }
  }
}

input {
  source = "<div v-memo=\"[value]\">{{ computed }}</div>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "TO_DISPLAY_STRING"
    }
    new HelperExpectation {
      name = "CREATE_TEXT"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
    new HelperExpectation {
      name = "WITH_MEMO"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { toDisplayString: _toDisplayString, createTextVNode: _createTextVNode, openBlock: _openBlock, createElementBlock: _createElementBlock, withMemo: _withMemo } = _Vue
  
      return _withMemo([value], () => (_openBlock(), _createElementBlock("div", null, [
        _createTextVNode(_toDisplayString(computed), 1 /* TEXT */)
      ])), _cache, 0)
    }
  }
  """#
}
