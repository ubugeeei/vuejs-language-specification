amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-v-slot-slot-with-v-for"
title = "Imported template input: slot with v-for"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/v-slot.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.v-slot"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/v-slot.toml"
  source = "tests/fixtures/vdom/v-slot.toml"
  caseName = "slot with v-for"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/v-slot.toml"
    cases {
      "slot with v-for"
    }
  }
}

input {
  source = "<MyComponent><template #item v-for=\"item in items\" :key=\"item.id\">{{ item }}</template></MyComponent>"
}

expect {
  helpers {
    new HelperExpectation {
      name = "TO_DISPLAY_STRING"
    }
    new HelperExpectation {
      name = "CREATE_TEXT"
    }
    new HelperExpectation {
      name = "RESOLVE_COMPONENT"
    }
    new HelperExpectation {
      name = "WITH_CTX"
    }
    new HelperExpectation {
      name = "RENDER_LIST"
    }
    new HelperExpectation {
      name = "CREATE_SLOTS"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_BLOCK"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { toDisplayString: _toDisplayString, createTextVNode: _createTextVNode, resolveComponent: _resolveComponent, withCtx: _withCtx, renderList: _renderList, createSlots: _createSlots, openBlock: _openBlock, createBlock: _createBlock } = _Vue
  
      const _component_MyComponent = _resolveComponent("MyComponent")
  
      return (_openBlock(), _createBlock(_component_MyComponent, null, _createSlots({ _: 2 /* DYNAMIC */ }, [
        _renderList(items, (item) => {
          return {
            name: "item",
            fn: _withCtx(() => [
              _createTextVNode(_toDisplayString(item), 1 /* TEXT */)
            ])
          }
        })
      ]), 1024 /* DYNAMIC_SLOTS */))
    }
  }
  """#
}
