amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-vdom-v-model-input-checkbox"
title = "Imported template input: input checkbox"
kind = "template-dom-compile"
summary = "Static template compiler conformance derived from copied input tests/fixtures/vdom/v-model.toml and the official vuejs/core compiler oracle."

features {
  "compiler.template"
  "imported.input"
  "imported.input.vdom"
  "imported.input.v-model"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/vdom/v-model.toml"
  source = "tests/fixtures/vdom/v-model.toml"
  caseName = "input checkbox"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/vdom/v-model.toml"
    cases {
      "input checkbox"
    }
  }
}

input {
  source = "<input type=\"checkbox\" v-model=\"checked\">"
}

expect {
  helpers {
    new HelperExpectation {
      name = "V_MODEL_CHECKBOX"
    }
    new HelperExpectation {
      name = "WITH_DIRECTIVES"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
  }
  hoistCount = 0
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { vModelCheckbox: _vModelCheckbox, withDirectives: _withDirectives, openBlock: _openBlock, createElementBlock: _createElementBlock } = _Vue
  
      return _withDirectives((_openBlock(), _createElementBlock("input", {
        type: "checkbox",
        "onUpdate:modelValue": $event => ((checked) = $event)
      }, null, 8 /* PROPS */, ["onUpdate:modelValue"])), [
        [_vModelCheckbox, checked]
      ])
    }
  }
  """#
}
