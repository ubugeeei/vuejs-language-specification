amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.template.vize-transform-errors-v-model-argument-on-native-element"
title = "Imported transform input: v-model argument on native element"
kind = "template-dom-compile"
summary = "Static compiler conformance derived from copied input tests/fixtures/errors/transform-errors.toml and the official vuejs/core compiler oracle, including exact diagnostics when emitted."

features {
  "compiler.template"
  "compiler.errors"
  "imported.input"
  "imported.input.transform-errors"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/errors/transform-errors.toml"
  source = "tests/fixtures/errors/transform-errors.toml"
  caseName = "v-model argument on native element"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-dom"
  operation = "compile"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/errors/transform-errors.toml"
    cases {
      "v-model argument on native element"
    }
  }
}

input {
  source = "<input v-model:value=\"text\" />"
}

expect {
  helpers {
    new HelperExpectation {
      name = "V_MODEL_TEXT"
    }
    new HelperExpectation {
      name = "WITH_DIRECTIVES"
    }
    new HelperExpectation {
      name = "OPEN_BLOCK"
    }
    new HelperExpectation {
      name = "CREATE_ELEMENT_BLOCK"
    }
  }
  hoistCount = 0
  diagnostics {
    new ErrorExpectation {
      name = "SyntaxError"
      message = "v-model argument is not supported on plain elements."
      code = "X_V_MODEL_ARG_ON_ELEMENT"
    }
  }
  normalizedCode = #"""
  const _Vue = Vue
  
  return function render(_ctx, _cache) {
    with (_ctx) {
      const { vModelText: _vModelText, withDirectives: _withDirectives, openBlock: _openBlock, createElementBlock: _createElementBlock } = _Vue
  
      return _withDirectives((_openBlock(), _createElementBlock("input", {
        value: text,
        "onUpdate:value": $event => ((text) = $event)
      }, null, 40 /* PROPS, NEED_HYDRATION */, ["value", "onUpdate:value"])), [
        [_vModelText, text, "value"]
      ])
    }
  }
  """#
}
