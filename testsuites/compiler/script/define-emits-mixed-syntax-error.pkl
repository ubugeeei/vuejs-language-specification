amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.script.define-emits-mixed-syntax-error"
title = "defineEmits rejects mixed property and call-signature syntax"
kind = "sfc-script-compile"
summary = "The defineEmits type parameter must not mix property syntax and call signatures inside the same declaration."

features {
  "script-setup.defineEmits"
  "compiler.script"
  "compiler.error"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__/compileScript/defineEmits.spec.ts"
    cases {
      "mixed usage of property / call signature"
    }
  }
}

input {
  filename = "DefineEmitsMixedSyntaxError.vue"
  sfc = #"""
    <script setup lang="ts">
    defineEmits<{
      foo: []
      (e: "hi"): void
    }>()
    </script>
    """#
  scriptOptions {
    id = "define-emits-mixed-syntax-error"
  }
}

expect {
  error {
    name = "Error"
    message = #"""
      [@vue/compiler-sfc] defineEmits() type cannot mixed call signature and property syntax.

      DefineEmitsMixedSyntaxError.vue
      1  |  <script setup lang="ts">
      2  |  defineEmits<{
         |              ^
      3  |    foo: []
         |  ^^^^^^^^^
      4  |    (e: "hi"): void
         |  ^^^^^^^^^^^^^^^^^
      5  |  }>()
         |  ^
      """#
  }
}
