amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.script.define-props-destructure-non-identifier-key"
title = "Reactive props destructure supports non-identifier prop keys"
kind = "sfc-script-compile"
summary = "String-literal prop keys that are not valid identifiers must still be addressable through destructure aliases and rewrite to bracket-based props access."

features {
  "script-setup.defineProps"
  "script-setup.destructure"
  "compiler.script"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__/compileScript/definePropsDestructure.spec.ts"
    cases {
      "non-identifier prop names"
    }
  }
}

input {
  filename = "definePropsDestructureNonIdentifierKey.vue"
  sfc = #"""
    <script setup>
    const { "foo.bar": fooBar } = defineProps({ "foo.bar": Function })
    let x = fooBar
    </script>
    <template>{{ fooBar }}</template>
    """#
  scriptOptions {
    id = "define-props-destructure-non-identifier-key"
    inlineTemplate = true
  }
}

expect {
  bindings {
    new BindingExpectation {
      name = "foo.bar"
      kind = "props"
    }
    new BindingExpectation {
      name = "fooBar"
      kind = "props-aliased"
    }
    new BindingExpectation {
      name = "x"
      kind = "setup-let"
    }
  }
  propConstructors {
    new PropConstructorExpectation {
      name = "foo.bar"
      constructor = "Function"
    }
  }
  normalizedCode = #"""
    import { toDisplayString as _toDisplayString } from "vue"


    export default {
      __name: 'definePropsDestructureNonIdentifierKey',
      props: { "foo.bar": Function },
      setup(__props) {


    let x = __props["foo.bar"]

    return (_ctx, _cache) => {
      return _toDisplayString(__props["foo.bar"])
    }
    }

    }
    """#
}
