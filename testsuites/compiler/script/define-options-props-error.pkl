amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.script.define-options-props-error"
title = "defineOptions rejects props declarations"
kind = "sfc-script-compile"
summary = "defineOptions must not be used to declare props and must emit the stable compiler-sfc diagnostic that redirects the author to defineProps."

features {
  "script-setup.defineOptions"
  "compiler.script"
  "compiler.error"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__/compileScript/defineOptions.spec.ts"
    cases {
      "should emit an error with props or emits property"
    }
  }
}

input {
  filename = "DefineOptionsPropsError.vue"
  sfc = #"""
    <script setup>
    defineOptions({ props: { foo: String } })
    </script>
    """#
  scriptOptions {
    id = "define-options-props-error"
  }
}

expect {
  error {
    name = "Error"
    message = #"""
      [@vue/compiler-sfc] defineOptions() cannot be used to declare props. Use defineProps() instead.

      DefineOptionsPropsError.vue
      1  |  <script setup>
      2  |  defineOptions({ props: { foo: String } })
         |                  ^^^^^^^^^^^^^^^^^^^^^^
      3  |  </script>
      """#
  }
}
