amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.script.define-expose-basic"
title = "defineExpose lowers into the setup expose bridge"
kind = "sfc-script-compile"
summary = "defineExpose must erase the macro call, bind the setup expose channel, and invoke that channel with the exposed object literal."

features {
  "script-setup.defineExpose"
  "compiler.script"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__/compileScript/defineExpose.spec.ts"
    cases {
      "defineExpose()"
    }
  }
}

input {
  filename = "defineExpose.vue"
  sfc = #"""
    <script setup>
    defineExpose({ foo: 123 })
    </script>
    """#
  scriptOptions {
    id = "define-expose-basic"
  }
}

expect {
  normalizedCode = #"""

    export default {
      __name: 'defineExpose',
      setup(__props, { expose: __expose }) {

    __expose({ foo: 123 })

    const __returned__ = {  }
    Object.defineProperty(__returned__, '__isScriptSetup', { enumerable: false, value: true })
    return __returned__
    }

    }
    """#
}
