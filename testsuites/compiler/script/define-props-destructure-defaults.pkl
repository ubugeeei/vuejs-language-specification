amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.script.define-props-destructure-defaults"
title = "Reactive props destructure defaults lower to runtime prop defaults"
kind = "sfc-script-compile"
summary = "Typed defineProps destructure defaults must still produce runtime props with constructor metadata and preserved literal defaults."

features {
  "script-setup.defineProps"
  "script-setup.destructure"
  "compiler.script"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-sfc/__tests__/compileScript/definePropsDestructure.spec.ts"
    cases {
      "default values w/ type declaration"
    }
  }
}

input {
  filename = "DestructureDefaults.vue"
  sfc = #"""
    <script setup lang="ts">
    const { foo = 1, bar = {}, func = () => {} } = defineProps<{
      foo?: number
      bar?: object
      func?: () => any
    }>()
    </script>
    """#
  scriptOptions {
    id = "destructure-defaults"
  }
}

expect {
  bindings {
    new BindingExpectation {
      name = "foo"
      kind = "props"
    }
    new BindingExpectation {
      name = "bar"
      kind = "props"
    }
    new BindingExpectation {
      name = "func"
      kind = "props"
    }
  }
  propConstructors {
    new PropConstructorExpectation {
      name = "foo"
      constructor = "Number"
    }
    new PropConstructorExpectation {
      name = "bar"
      constructor = "Object"
    }
    new PropConstructorExpectation {
      name = "func"
      constructor = "Function"
    }
  }
  propDefaults {
  }
  propDefaultKinds {
    new DefaultKindExpectation {
      name = "foo"
      kind = "literal"
    }
    new DefaultKindExpectation {
      name = "bar"
      kind = "callable"
    }
    new DefaultKindExpectation {
      name = "func"
      kind = "callable"
    }
  }
}
