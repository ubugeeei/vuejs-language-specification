amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.jsx-vapor.restructure-arrow-function"
title = "JSX Vapor restructure preserves arrow-function props access"
kind = "jsx-expected-snapshot"
summary = "JSX Vapor parameter restructure must rewrite arrow-function destructure reads to canonical __props access without changing the JSX return surface."

features {
  "compiler.snapshot"
  "compiler.profile.jsx-vapor"
  "compiler.jsx-vapor"
  "jsx-vapor.restructure"
  "jsx-vapor.destructure"
  "imported.input"
  "imported.input.jsx-vapor"
}

profile = "jsx-vapor"

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/vuejs-vue-jsx-vapor/packages/macros/tests/restructure.spec.ts"
  source = "packages/macros/tests/restructure.spec.ts"
  caseName = "reconstruct arrowFunctionExpression"
  originRepository = "vuejs/vue-jsx-vapor"
}

oracle = new ReferenceOracle {
  repository = "vuejs/vue-jsx-vapor"
  moduleName = "@vue-jsx-vapor/macros/restructure"
  operation = "copied snapshot oracle via restructure"
  profile = "jsx-vapor"
  provisional = true
}

upstream {
  new UpstreamReference {
    repository = "vuejs/vue-jsx-vapor"
    source = "packages/macros/tests/restructure.spec.ts"
    cases {
      "reconstruct arrowFunctionExpression"
    }
  }
  new UpstreamReference {
    kind = "snapshot"
    repository = "vuejs/vue-jsx-vapor"
    source = "packages/macros/tests/__snapshots__/restructure.spec.ts.snap"
    cases {
      "transform > reconstruct arrowFunctionExpression 1"
    }
  }
}

input {
  source = #"""
  const App = ([{root: {foo}}]) => (
          <>{[foo]}</>
        )
  """#
}

expect {
  normalizedCode = #"""
  const App = (__props) => (
          <>{[__props[0].root.foo]}</>
        )
  """#
  vendoredSnapshotOutput = #"""
  const App = (__props) => (
          <>{[__props[0].root.foo]}</>
        )
  """#
}

