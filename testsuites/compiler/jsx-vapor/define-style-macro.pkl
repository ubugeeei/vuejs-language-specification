amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.jsx-vapor.define-style-macro"
title = "JSX Vapor defineStyle lowering"
kind = "jsx-expected-snapshot"
summary = "JSX Vapor macro compilation must inject scoped style imports, CSS variable bindings, and slot scope ids exactly as recorded in the copied snapshot oracle."

features {
  "compiler.snapshot"
  "compiler.profile.jsx-vapor"
  "compiler.jsx-vapor"
  "jsx-vapor.defineStyle"
  "imported.input"
  "imported.input.jsx-vapor"
}

profile = "jsx-vapor"

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/vuejs-vue-jsx-vapor/packages/macros/tests/fixtures/define-style.tsx"
  source = "packages/macros/tests/fixtures/define-style.tsx"
  caseName = "./fixtures/define-style.tsx"
  originRepository = "vuejs/vue-jsx-vapor"
}

oracle = new ReferenceOracle {
  repository = "vuejs/vue-jsx-vapor"
  moduleName = "@vue-jsx-vapor/macros"
  operation = "copied snapshot oracle via transformJsxMacros"
  profile = "jsx-vapor"
  provisional = true
}

upstream {
  new UpstreamReference {
    repository = "vuejs/vue-jsx-vapor"
    source = "packages/macros/tests/fixtures/define-style.tsx"
    cases {
      "./fixtures/define-style.tsx"
    }
  }
  new UpstreamReference {
    kind = "snapshot"
    repository = "vuejs/vue-jsx-vapor"
    source = "packages/macros/tests/__snapshots__/fixtures.spec.ts.snap"
    cases {
      "fixtures > ./fixtures/define-style.tsx 1"
    }
  }
}

input {
  source = #"""
  import { defineComponent, ref } from 'vue'
  
  export const Comp = () => {
    const color = ref('red')
    defineStyle(`
      .foo {
        color: ${color.value};
      }
    `)
    return <div class="foo">foo</div>
  }
  
  export default defineComponent(() => {
    const color = ref('red')
    const styles = defineStyle.scss(`
      .bar {
        color: ${color.value};
        .bar-baz {
          background: red;
        }
      }
    `)
    const { default: Default, ...slots } = defineSlots()
    return () => (
      <>
        <div class={styles.bar}>foo</div>
        <div class="bar">
          <span class={styles['bar-baz']}>bar</span>
        </div>
  
        <Default />
        <slots.title />
      </>
    )
  })
  
  defineStyle.scss(`
    .bar {
      color: red;
    }
  `)
  
  """#
}

