amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.jsx-vapor.restructure-assignment-pattern"
title = "JSX Vapor restructure lowers nested assignment patterns through default proxies"
kind = "jsx-expected-snapshot"
summary = "JSX Vapor parameter restructure must lower nested assignment patterns to createPropsDefaultProxy with stable path-based keys that match the copied snapshot oracle."

features {
  "compiler.snapshot"
  "compiler.profile.jsx-vapor"
  "compiler.jsx-vapor"
  "jsx-vapor.restructure"
  "jsx-vapor.assignment-pattern"
  "imported.input"
  "imported.input.jsx-vapor"
}

profile = "jsx-vapor"

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/vuejs-vue-jsx-vapor/packages/macros/tests/restructure.spec.ts"
  source = "packages/macros/tests/restructure.spec.ts"
  caseName = "reconstruct AssignmentPattern"
  originRepository = "vuejs/vue-jsx-vapor"
}

oracle = new ReferenceOracle {
  repository = "vuejs/vue-jsx-vapor"
  moduleName = "@vue-jsx-vapor/macros/restructure"
  operation = "copied snapshot oracle via restructure"
  profile = "jsx-vapor"
  provisional = true
}

upstream {
  new UpstreamReference {
    repository = "vuejs/vue-jsx-vapor"
    source = "packages/macros/tests/restructure.spec.ts"
    cases {
      "reconstruct AssignmentPattern"
    }
  }
  new UpstreamReference {
    kind = "snapshot"
    repository = "vuejs/vue-jsx-vapor"
    source = "packages/macros/tests/__snapshots__/restructure.spec.ts.snap"
    cases {
      "transform > reconstruct AssignmentPattern 1"
    }
  }
}

input {
  source = #"""
  function App({foo: {foo = 1} = ({} as any)!, bar: [bar = 2] = []}){
          return <>{[foo, bar]}</>
        }
  """#
}

expect {
  normalizedCode = #"""
  
  import { createPropsDefaultProxy as __createPropsDefaultProxy } from "/vue-jsx-vapor/macros/with-defaults";function App(__props){
  __props = __createPropsDefaultProxy(__props, {'.foo.foo': 1, '.bar[0]': 2});
          return <>{[__props.foo.foo, __props.bar[0]]}</>
        }
  """#
  vendoredSnapshotOutput = #"""
  
  import { createPropsDefaultProxy as __createPropsDefaultProxy } from "/vue-jsx-vapor/macros/with-defaults";function App(__props){
  __props = __createPropsDefaultProxy(__props, {'.foo.foo': 1, '.bar[0]': 2});
          return <>{[__props.foo.foo, __props.bar[0]]}</>
        }
  """#
}

