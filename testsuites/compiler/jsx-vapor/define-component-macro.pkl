amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.jsx-vapor.define-component-macro"
title = "JSX Vapor defineComponent and defineVaporComponent macro lowering"
kind = "jsx-expected-snapshot"
summary = "JSX Vapor macro compilation must preserve the authored VDOM or Vapor component surface while collecting referenced props, async setup rewrites, and model channels into the copied snapshot oracle."

features {
  "compiler.snapshot"
  "compiler.profile.jsx-vapor"
  "compiler.jsx-vapor"
  "jsx-vapor.defineComponent"
  "imported.input"
  "imported.input.jsx-vapor"
}

profile = "jsx-vapor"

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/vuejs-vue-jsx-vapor/packages/macros/tests/fixtures/define-component.tsx"
  source = "packages/macros/tests/fixtures/define-component.tsx"
  caseName = "./fixtures/define-component.tsx"
  originRepository = "vuejs/vue-jsx-vapor"
}

oracle = new ReferenceOracle {
  repository = "vuejs/vue-jsx-vapor"
  moduleName = "@vue-jsx-vapor/macros"
  operation = "copied snapshot oracle via transformJsxMacros"
  profile = "jsx-vapor"
  provisional = true
}

upstream {
  new UpstreamReference {
    repository = "vuejs/vue-jsx-vapor"
    source = "packages/macros/tests/fixtures/define-component.tsx"
    cases {
      "./fixtures/define-component.tsx"
    }
  }
  new UpstreamReference {
    kind = "snapshot"
    repository = "vuejs/vue-jsx-vapor"
    source = "packages/macros/tests/__snapshots__/fixtures.spec.ts.snap"
    cases {
      "fixtures > ./fixtures/define-component.tsx 1"
    }
  }
}

input {
  source = #"""
  import { defineComponent, defineVaporComponent, nextTick, unref } from 'vue'
  
  const $ = unref
  
  const Comp = defineVaporComponent(
    ({
      bar = 'bar'! as string,
      Comp,
      ...attrs
    }: {
      bar: string
      baz: 'baz'
      Comp: any
    }) => {
      defineModel()
      const foo = $(
        defineModel('foo', {
          validator: (value) => {
            return value === 'foo'
          },
          type: String,
        })!,
      )
      return (
        <div>
          {[foo, bar, attrs.baz]}
          <Comp />
        </div>
      )
    },
    { name: 'Comp', props: { Comp: Object } },
  )
  
  const Comp1 = defineVaporComponent(
    (props: { bar: 'bar'; 'onUpdate:bar': any; comp: any }) => {
      const foo = defineModel('foo')
      return (
        <div>
          {[foo.value, props['bar'], props['onUpdate:bar']]}
          <props.comp />
        </div>
      )
    },
  )
  
  const Comp2 = defineComponent(async () => {
    await nextTick()
    let foo = await new Promise((resolve) => {
      setTimeout(() => resolve('foo'), 1000)
    })
    return () => <div>{foo}</div>
  })
  
  const foo = () => {}
  defineVaporComponent(
    ({
      a = 0,
      b = 'b',
      c = true,
      d = () => {},
      e = {},
      f = [],
      g = foo,
      h = null,
      i = undefined!,
    }) => {
      return (
        <>
          {a}
          {b}
          {c}
          {d}
          {e}
          {f}
          {g}
          {h}
          {i}
        </>
      )
    },
  )
  
  // #21
  const Comp3 = defineComponent(<T,>() => {
    return () => <div>123</div>
  })
  const Comp4 = defineVaporComponent(<T,>() => {
    return <div>123</div>
  })
  
  """#
}

expect {
  normalizedCode = #"""
  
  import { useAttrs as __useAttrs } from "vue";
  import { useModel as __useModel } from "/vue-jsx-vapor/macros/use-model";
  import { useFullProps as __useFullProps } from "/vue-jsx-vapor/props";
  import { withAsyncContext as __withAsyncContext } from "vue";import { defineComponent, defineVaporComponent, nextTick, unref } from 'vue'
  
  const $ = unref
  
  const Comp = defineVaporComponent(
    (__props) => {const attrs = __useAttrs();
      __useModel(__props, 'modelValue',)
      const foo = $(
        __useModel(__props, 'foo', {
          validator: (value) => {
            return value === 'foo'
          },
          type: String,
        })!,
      )
      return (
        <div>
          {[foo, __props.bar, attrs.baz]}
          <__props.Comp />
        </div>
      )
    },
    { inheritAttrs: false, props: {
  'bar': { required: true, type: String, default: 'bar' }, 
  'Comp': null, 
  'modelValue': null, 
  'onUpdate:modelValue': null, 
  'modelModifiers': null, 
  'foo': { required: true, validator: (value) => {
            return value === 'foo'
          }, type: String }, 
  'onUpdate:foo': null, 
  'fooModifiers': null
  }, ...{ name: 'Comp', props: { Comp: Object } } },
  )
  
  const Comp1 = defineVaporComponent(
    () => {const props = __useFullProps();
      const foo = __useModel(props, 'foo')
      return (
        <div>
          {[foo.value, props['bar'], props['onUpdate:bar']]}
          <props.comp />
        </div>
      )
    }, { props: {
  'bar': null, 
  'onUpdate:bar': null, 
  'comp': null, 
  'foo': null, 
  'onUpdate:foo': null, 
  'fooModifiers': null
  } },
  )
  
  const Comp2 = defineComponent(async () => {
  let __temp, __restore
  
    ;(
    ([__temp,__restore] = __withAsyncContext(() => nextTick())),
    await __temp,
    __restore()
  )
    let foo = (
    ([__temp,__restore] = __withAsyncContext(() => new Promise((resolve) => {
      setTimeout(() => resolve('foo'), 1000)
    }))),
    __temp = await __temp,
    __restore(),
    __temp
  )
    return () => <div>{foo}</div>
  })
  
  const foo = () => {}
  defineVaporComponent(
    (__props) => {
      return (
        <>
          {__props.a}
          {__props.b}
          {__props.c}
          {__props.d}
          {__props.e}
          {__props.f}
          {__props.g}
          {__props.h}
          {__props.i}
        </>
      )
    }, { props: {
  'a': { type: Number, default: 0 }, 
  'b': { type: String, default: 'b' }, 
  'c': { type: Boolean, default: true }, 
  'd': { type: Function, default: () => {} }, 
  'e': { type: Object, default: () => ({}) }, 
  'f': { type: Array, default: () => ([]) }, 
  'g': { default: foo, skipFactory: true }, 
  'h': { default: null }, 
  'i': { required: true, default: undefined }
  } },
  )
  
  // #21
  const Comp3 = defineComponent(<T,>() => {
    return () => <div>123</div>
  })
  const Comp4 = defineVaporComponent(<T,>() => {
    return <div>123</div>
  })
  
  """#
