input {
  filename = "compiler.sfc.vize-sfc-patches-v-for-with-v-click-outside.vue"
  sfc = #"""
  <script setup>
  import { ref } from 'vue'
  const items = ref([{ id: 1, name: 'Item 1' }])
  function closeItem(id) {
    console.log('close', id)
  }
  </script>
  
  <template>
    <div v-for="item in items" :key="item.id" v-click-outside="() => closeItem(item.id)">
      {{ item.name }}
    </div>
  </template>
  
  """#
}

expect {
    descriptor = new DescriptorExpectation {
      template = true
      script = false
      scriptSetup = true
