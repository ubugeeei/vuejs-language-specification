amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.sfc.vize-sfc-basic-options-api-component"
title = "Imported SFC input: options API component"
kind = "sfc-full-compile"
summary = "Static SFC compiler pipeline conformance derived from copied input tests/fixtures/sfc/basic.toml and the official vuejs/core SFC oracle."

features {
  "compiler.sfc"
  "imported.input"
  "imported.input.sfc"
  "imported.input.basic"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/sfc/basic.toml"
  source = "tests/fixtures/sfc/basic.toml"
  caseName = "options API component"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-sfc"
  operation = "parse + compileScript + compileTemplate + compileStyle"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/sfc/basic.toml"
    cases {
      "options API component"
    }
  }
}

input {
  filename = "compiler.sfc.vize-sfc-basic-options-api-component.vue"
  sfc = #"""
  <script>
  export default {
    data() {
      return { msg: 'hello' }
    }
  }
  </script>
  
  <template>
    <div>{{ msg }}</div>
  </template>
  
  """#
}

expect {
    descriptor = new DescriptorExpectation {
      template = true
      script = true
      scriptSetup = false
      styles = 0
      customBlocks = 0
      scopedStyles = 0
    }
  normalizedCode = #"""
  
  export default {
    data() {
      return { msg: 'hello' }
    }
  }
  
  """#
  templateCode = #"""
  import { toDisplayString as _toDisplayString, openBlock as _openBlock, createElementBlock as _createElementBlock } from "vue"
  
  export function render(_ctx, _cache, $props, $setup, $data, $options) {
    return (_openBlock(), _createElementBlock("div", null, _toDisplayString($data.msg), 1 /* TEXT */))
  }
  """#
}
