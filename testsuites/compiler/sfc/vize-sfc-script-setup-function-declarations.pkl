amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.sfc.vize-sfc-script-setup-function-declarations"
title = "Imported SFC input: function declarations"
kind = "sfc-full-compile"
summary = "Static SFC compiler pipeline conformance derived from copied input tests/fixtures/sfc/script-setup.toml and the official vuejs/core SFC oracle."

features {
  "compiler.sfc"
  "imported.input"
  "imported.input.sfc"
  "imported.input.script-setup"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/sfc/script-setup.toml"
  source = "tests/fixtures/sfc/script-setup.toml"
  caseName = "function declarations"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-sfc"
  operation = "parse + compileScript + compileTemplate + compileStyle"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/sfc/script-setup.toml"
    cases {
      "function declarations"
    }
  }
}

input {
  filename = "compiler.sfc.vize-sfc-script-setup-function-declarations.vue"
  sfc = #"""
  <script setup>
  function increment() {
    count++
  }
  const handler = () => {}
  </script>
  
  <template>
    <button @click="increment">Click</button>
  </template>
  
  """#
}

expect {
    descriptor = new DescriptorExpectation {
      template = true
      script = false
      scriptSetup = true
      styles = 0
      customBlocks = 0
      scopedStyles = 0
    }
  normalizedCode = #"""
  
  export default {
    __name: 'compiler.sfc.vize-sfc-script-setup-function-declarations',
    setup(__props, { expose: __expose }) {
    __expose();
  
  function increment() {
    count++
  }
  const handler = () => {}
  
  const __returned__ = { increment, handler }
  Object.defineProperty(__returned__, '__isScriptSetup', { enumerable: false, value: true })
  return __returned__
  }
  
  }
  """#
  templateCode = #"""
  import { openBlock as _openBlock, createElementBlock as _createElementBlock } from "vue"
  
  export function render(_ctx, _cache, $props, $setup, $data, $options) {
    return (_openBlock(), _createElementBlock("button", { onClick: $setup.increment }, "Click"))
  }
  """#
}
