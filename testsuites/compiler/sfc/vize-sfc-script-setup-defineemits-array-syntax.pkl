amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.sfc.vize-sfc-script-setup-defineemits-array-syntax"
title = "Imported SFC input: defineEmits array syntax"
kind = "sfc-full-compile"
summary = "Static SFC compiler pipeline conformance derived from copied input tests/fixtures/sfc/script-setup.toml and the official vuejs/core SFC oracle."

features {
  "compiler.sfc"
  "imported.input"
  "imported.input.sfc"
  "imported.input.script-setup"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/sfc/script-setup.toml"
  source = "tests/fixtures/sfc/script-setup.toml"
  caseName = "defineEmits array syntax"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-sfc"
  operation = "parse + compileScript + compileTemplate + compileStyle"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/sfc/script-setup.toml"
    cases {
      "defineEmits array syntax"
    }
  }
}

input {
  filename = "compiler.sfc.vize-sfc-script-setup-defineemits-array-syntax.vue"
  sfc = #"""
  <script setup>
  const emit = defineEmits(['update', 'change'])
  function onClick() {
    emit('update', 1)
  }
  </script>
  
  <template>
    <button @click="onClick">Click</button>
  </template>
  
  """#
}

expect {
    descriptor = new DescriptorExpectation {
      template = true
      script = false
      scriptSetup = true
      styles = 0
      customBlocks = 0
      scopedStyles = 0
    }
  normalizedCode = #"""
  
  export default {
    __name: 'compiler.sfc.vize-sfc-script-setup-defineemits-array-syntax',
    emits: ['update', 'change'],
    setup(__props, { expose: __expose, emit: __emit }) {
    __expose();
  
  const emit = __emit
  function onClick() {
    emit('update', 1)
  }
  
  const __returned__ = { emit, onClick }
  Object.defineProperty(__returned__, '__isScriptSetup', { enumerable: false, value: true })
  return __returned__
  }
  
  }
  """#
  templateCode = #"""
  import { openBlock as _openBlock, createElementBlock as _createElementBlock } from "vue"
  
  export function render(_ctx, _cache, $props, $setup, $data, $options) {
    return (_openBlock(), _createElementBlock("button", { onClick: $setup.onClick }, "Click"))
  }
  """#
}
