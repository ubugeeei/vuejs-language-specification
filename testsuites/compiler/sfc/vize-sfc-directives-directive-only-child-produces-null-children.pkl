amends "../../../schemas/CompilerTestSuite.pkl"

id = "compiler.sfc.vize-sfc-directives-directive-only-child-produces-null-children"
title = "Imported SFC input: directive only child produces null children"
kind = "sfc-full-compile"
summary = "Static SFC compiler pipeline conformance derived from copied input tests/fixtures/sfc/directives.toml and the official vuejs/core SFC oracle."

features {
  "compiler.sfc"
  "imported.input"
  "imported.input.sfc"
  "imported.input.directives"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/sfc/directives.toml"
  source = "tests/fixtures/sfc/directives.toml"
  caseName = "directive only child produces null children"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-sfc"
  operation = "parse + compileScript + compileTemplate + compileStyle"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/sfc/directives.toml"
    cases {
      "directive only child produces null children"
    }
  }
}

input {
  filename = "compiler.sfc.vize-sfc-directives-directive-only-child-produces-null-children.vue"
  sfc = #"""
  <script setup>
  </script>
  
  <template>
    <div>
      <!-- @vize:dev-only -->
    </div>
  </template>
  
  """#
}

expect {
    descriptor = new DescriptorExpectation {
      template = true
      script = false
      scriptSetup = false
      styles = 0
      customBlocks = 0
      scopedStyles = 0
    }
  templateCode = #"""
  import { createCommentVNode as _createCommentVNode, openBlock as _openBlock, createElementBlock as _createElementBlock } from "vue"
  
  export function render(_ctx, _cache) {
    return (_openBlock(), _createElementBlock("div", null, [
      _createCommentVNode(" @vize:dev-only ")
    ]))
  }
  """#
}
