amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-element-element-with-interpolation-child"
title = "Imported parser input: element with interpolation child"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/element.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.element"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/element.toml"
  source = "tests/fixtures/parser/element.toml"
  caseName = "element with interpolation child"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/element.toml"
    cases {
      "element with interpolation child"
    }
  }
}

input {
  source = "<div>{{ message }}</div>"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "<div>{{ message }}</div>",
    "children": [
      {
        "type": "ELEMENT",
        "tag": "div",
        "ns": "HTML",
        "tagType": "ELEMENT",
        "props": [],
        "children": [
          {
            "type": "INTERPOLATION",
            "content": {
              "type": "SIMPLE_EXPRESSION",
              "loc": {
                "start": {
                  "column": 9,
                  "line": 1,
                  "offset": 8
                },
                "end": {
                  "column": 16,
                  "line": 1,
                  "offset": 15
                },
                "source": "message"
              },
              "content": "message",
              "isStatic": false,
              "constType": "NOT_CONSTANT"
            },
            "loc": {
              "start": {
                "column": 6,
                "line": 1,
                "offset": 5
              },
              "end": {
                "column": 19,
                "line": 1,
                "offset": 18
              },
              "source": "{{ message }}"
            }
          }
        ],
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 25,
            "line": 1,
            "offset": 24
          },
          "source": "<div>{{ message }}</div>"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 25,
        "line": 1,
        "offset": 24
      },
      "source": "<div>{{ message }}</div>"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/children/0/content/constType"
      equals = "NOT_CONSTANT"
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/content/content"
      equals = "message"
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/content/isStatic"
      equals = false
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/content/loc/end/column"
