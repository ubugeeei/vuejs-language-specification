amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-interpolation-simple-interpolation"
title = "Imported parser input: simple interpolation"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/interpolation.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.interpolation"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/interpolation.toml"
  source = "tests/fixtures/parser/interpolation.toml"
  caseName = "simple interpolation"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/interpolation.toml"
    cases {
      "simple interpolation"
    }
  }
}

input {
  source = "{{message}}"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "{{message}}",
    "children": [
      {
        "type": "INTERPOLATION",
        "content": {
          "type": "SIMPLE_EXPRESSION",
          "loc": {
            "start": {
              "column": 3,
              "line": 1,
              "offset": 2
            },
            "end": {
              "column": 10,
              "line": 1,
              "offset": 9
            },
            "source": "message"
          },
          "content": "message",
          "isStatic": false,
          "constType": "NOT_CONSTANT"
        },
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 12,
            "line": 1,
            "offset": 11
          },
          "source": "{{message}}"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 12,
        "line": 1,
        "offset": 11
      },
      "source": "{{message}}"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/content/constType"
      equals = "NOT_CONSTANT"
    }
    new PointerAssertion {
      pointer = "/children/0/content/content"
      equals = "message"
    }
    new PointerAssertion {
      pointer = "/children/0/content/isStatic"
      equals = false
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/end/column"
      equals = 10
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/end/offset"
      equals = 9
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/source"
      equals = "message"
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/start/column"
      equals = 3
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/start/offset"
      equals = 2
    }
    new PointerAssertion {
      pointer = "/children/0/content/type"
      equals = "SIMPLE_EXPRESSION"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/column"
      equals = 12
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/offset"
      equals = 11
    }
    new PointerAssertion {
      pointer = "/children/0/loc/source"
      equals = "{{message}}"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/children/0/type"
      equals = "INTERPOLATION"
    }
    new PointerAssertion {
      pointer = "/loc/end/column"
      equals = 12
    }
    new PointerAssertion {
      pointer = "/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/end/offset"
      equals = 11
    }
    new PointerAssertion {
      pointer = "/loc/source"
      equals = "{{message}}"
    }
    new PointerAssertion {
      pointer = "/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/source"
      equals = "{{message}}"
    }
    new PointerAssertion {
      pointer = "/temps"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/type"
      equals = "ROOT"
    }
  }
}
