amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-text-text-with-triple-curly"
title = "Imported parser input: text with triple curly"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/text.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.text"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/text.toml"
  source = "tests/fixtures/parser/text.toml"
  caseName = "text with triple curly"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/text.toml"
    cases {
      "text with triple curly"
    }
  }
}

input {
  source = "{{{ not interpolation }}}"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "{{{ not interpolation }}}",
    "children": [
      {
        "type": "INTERPOLATION",
        "content": {
          "type": "SIMPLE_EXPRESSION",
          "loc": {
            "start": {
              "column": 3,
              "line": 1,
              "offset": 2
            },
            "end": {
              "column": 22,
              "line": 1,
              "offset": 21
            },
            "source": "{ not interpolation"
          },
          "content": "{ not interpolation",
          "isStatic": false,
          "constType": "NOT_CONSTANT"
        },
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 25,
            "line": 1,
            "offset": 24
          },
          "source": "{{{ not interpolation }}"
        }
      },
      {
        "type": "TEXT",
        "content": "}",
        "loc": {
          "start": {
            "column": 25,
            "line": 1,
            "offset": 24
          },
          "end": {
            "column": 26,
            "line": 1,
            "offset": 25
          },
          "source": "}"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 26,
        "line": 1,
        "offset": 25
      },
      "source": "{{{ not interpolation }}}"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/content/constType"
      equals = "NOT_CONSTANT"
    }
    new PointerAssertion {
      pointer = "/children/0/content/content"
      equals = "{ not interpolation"
    }
    new PointerAssertion {
      pointer = "/children/0/content/isStatic"
      equals = false
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/end/column"
      equals = 22
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/end/offset"
