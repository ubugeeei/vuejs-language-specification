amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.v-pre-literal-content"
title = "v-pre suspends directive and interpolation parsing within the preserved subtree"
summary = "When v-pre is present, directive syntax and interpolation delimiters inside the preserved subtree must remain literal parser output rather than directive or interpolation nodes."

features {
  "parser.v-pre"
  "parser.literal-subtree"
}

upstream {
  new UpstreamReference {
    repository = "vuejs/core"
    source = "packages/compiler-core/__tests__/parse.spec.ts"
    cases {
      "v-pre"
    }
  }
}

input {
  source = #"""
    <div v-pre :id="foo"><Comp/>{{ bar }}</div>
    """#
}

expect {
  errorCount = 0
  ast {
    new PointerAssertion {
      pointer = "/children/0/props/0/type"
      equals = "ATTRIBUTE"
    }
    new PointerAssertion {
      pointer = "/children/0/props/0/name"
      equals = ":id"
    }
    new PointerAssertion {
      pointer = "/children/0/props/0/value/content"
      equals = "foo"
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/tag"
      equals = "Comp"
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/tagType"
      equals = "ELEMENT"
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/isSelfClosing"
      equals = true
    }
    new PointerAssertion {
      pointer = "/children/0/children/1/type"
      equals = "TEXT"
    }
    new PointerAssertion {
      pointer = "/children/0/children/1/content"
      equals = "{{ bar }}"
    }
  }
}
