amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-attribute-attribute-with-newline-in-value"
title = "Imported parser input: attribute with newline in value"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/attribute.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.attribute"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/attribute.toml"
  source = "tests/fixtures/parser/attribute.toml"
  caseName = "attribute with newline in value"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/attribute.toml"
    cases {
      "attribute with newline in value"
    }
  }
}

input {
  source = #"""
  <div title="line1
  line2"></div>
  """#
}

