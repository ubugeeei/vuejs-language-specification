                "loc": {
                  "start": {
                    "column": 17,
                    "line": 1,
                    "offset": 16
                  },
                  "end": {
                    "column": 22,
                    "line": 1,
                    "offset": 21
                  },
                  "source": "world"
                }
              }
            ],
            "loc": {
              "start": {
                "column": 11,
                "line": 1,
                "offset": 10
              },
              "end": {
                "column": 29,
                "line": 1,
                "offset": 28
              },
              "source": "<span>world</span>"
            }
          }
        ],
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 35,
            "line": 1,
            "offset": 34
          },
          "source": "<div>hello<span>world</span></div>"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 35,
        "line": 1,
        "offset": 34
      },
      "source": "<div>hello<span>world</span></div>"
    }
  }
