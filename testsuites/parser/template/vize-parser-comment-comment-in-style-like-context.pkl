amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-comment-comment-in-style-like-context"
title = "Imported parser input: comment in style-like context"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/comment.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.comment"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/comment.toml"
  source = "tests/fixtures/parser/comment.toml"
  caseName = "comment in style-like context"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/comment.toml"
    cases {
      "comment in style-like context"
    }
  }
}

input {
  source = "<style><!-- not parsed --></style>"
}

