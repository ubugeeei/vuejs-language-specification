amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-comment-comment-between-text"
title = "Imported parser input: comment between text"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/comment.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.comment"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/comment.toml"
  source = "tests/fixtures/parser/comment.toml"
  caseName = "comment between text"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/comment.toml"
    cases {
      "comment between text"
    }
  }
}

input {
  source = "before<!-- comment -->after"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "before<!-- comment -->after",
    "children": [
      {
        "type": "TEXT",
        "content": "before",
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 7,
            "line": 1,
            "offset": 6
          },
          "source": "before"
        }
      },
      {
        "type": "COMMENT",
        "content": " comment ",
        "loc": {
          "start": {
            "column": 7,
            "line": 1,
            "offset": 6
          },
          "end": {
            "column": 23,
            "line": 1,
            "offset": 22
          },
          "source": "<!-- comment -->"
        }
      },
      {
        "type": "TEXT",
        "content": "after",
        "loc": {
          "start": {
            "column": 23,
            "line": 1,
            "offset": 22
          },
          "end": {
            "column": 28,
            "line": 1,
            "offset": 27
          },
          "source": "after"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 28,
        "line": 1,
        "offset": 27
      },
      "source": "before<!-- comment -->after"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/content"
      equals = "before"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/column"
      equals = 7
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/offset"
