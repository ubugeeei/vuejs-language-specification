amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-errors-parse-errors-invalid-tag-name-starting-with-slash"
title = "Imported parser input: invalid tag name starting with slash"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/errors/parse-errors.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.errors"
  "imported.input.parse-errors"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/errors/parse-errors.toml"
  source = "tests/fixtures/errors/parse-errors.toml"
  caseName = "invalid tag name starting with slash"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/errors/parse-errors.toml"
    cases {
      "invalid tag name starting with slash"
    }
  }
}

input {
  source = "</>"
}

expect {
  errorCount = 1
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "</>",
    "children": [],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 4,
        "line": 1,
        "offset": 3
      },
      "source": "</>"
    }
  }
  """#
  normalizedErrors = #"""
  [
    {
      "code": "MISSING_END_TAG_NAME",
      "loc": {
        "start": {
          "column": 3,
          "line": 1,
          "offset": 2
        },
        "end": {
          "column": 3,
          "line": 1,
          "offset": 2
        },
        "source": ""
      }
    }
  ]
  """#
  ast {
    new PointerAssertion {
      pointer = "/loc/end/column"
      equals = 4
    }
    new PointerAssertion {
      pointer = "/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/end/offset"
      equals = 3
    }
    new PointerAssertion {
      pointer = "/loc/source"
      equals = "</>"
    }
    new PointerAssertion {
      pointer = "/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/source"
      equals = "</>"
    }
    new PointerAssertion {
      pointer = "/temps"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/type"
      equals = "ROOT"
    }
  }
  errors {
    new PointerAssertion {
      pointer = "/0/code"
      equals = "MISSING_END_TAG_NAME"
    }
    new PointerAssertion {
      pointer = "/0/loc/end/column"
      equals = 3
    }
    new PointerAssertion {
      pointer = "/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/0/loc/end/offset"
      equals = 2
    }
    new PointerAssertion {
      pointer = "/0/loc/source"
      equals = ""
    }
    new PointerAssertion {
      pointer = "/0/loc/start/column"
      equals = 3
    }
    new PointerAssertion {
      pointer = "/0/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/0/loc/start/offset"
      equals = 2
    }
  }
}
