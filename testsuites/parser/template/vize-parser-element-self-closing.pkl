amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-element-self-closing"
title = "Imported parser input: self closing"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/element.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.element"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/element.toml"
  source = "tests/fixtures/parser/element.toml"
  caseName = "self closing"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/element.toml"
    cases {
      "self closing"
    }
  }
}

input {
  source = "<div/>after"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "<div/>after",
    "children": [
      {
        "type": "ELEMENT",
        "tag": "div",
        "ns": "HTML",
        "tagType": "ELEMENT",
        "props": [],
        "children": [],
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 7,
            "line": 1,
            "offset": 6
          },
          "source": "<div/>"
        },
        "isSelfClosing": true
      },
      {
        "type": "TEXT",
        "content": "after",
        "loc": {
          "start": {
            "column": 7,
            "line": 1,
            "offset": 6
          },
          "end": {
            "column": 12,
            "line": 1,
            "offset": 11
          },
          "source": "after"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 12,
        "line": 1,
        "offset": 11
      },
      "source": "<div/>after"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/isSelfClosing"
      equals = true
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/column"
      equals = 7
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/offset"
      equals = 6
    }
    new PointerAssertion {
      pointer = "/children/0/loc/source"
      equals = "<div/>"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/children/0/ns"
      equals = "HTML"
    }
    new PointerAssertion {
      pointer = "/children/0/tag"
      equals = "div"
    }
    new PointerAssertion {
      pointer = "/children/0/tagType"
      equals = "ELEMENT"
    }
    new PointerAssertion {
      pointer = "/children/0/type"
      equals = "ELEMENT"
    }
    new PointerAssertion {
      pointer = "/children/1/content"
      equals = "after"
    }
    new PointerAssertion {
      pointer = "/children/1/loc/end/column"
      equals = 12
    }
    new PointerAssertion {
      pointer = "/children/1/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/1/loc/end/offset"
      equals = 11
    }
    new PointerAssertion {
      pointer = "/children/1/loc/source"
      equals = "after"
    }
    new PointerAssertion {
      pointer = "/children/1/loc/start/column"
      equals = 7
    }
    new PointerAssertion {
      pointer = "/children/1/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/1/loc/start/offset"
      equals = 6
    }
    new PointerAssertion {
      pointer = "/children/1/type"
      equals = "TEXT"
    }
    new PointerAssertion {
      pointer = "/loc/end/column"
      equals = 12
    }
    new PointerAssertion {
      pointer = "/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/end/offset"
      equals = 11
    }
    new PointerAssertion {
      pointer = "/loc/source"
      equals = "<div/>after"
    }
    new PointerAssertion {
      pointer = "/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/source"
      equals = "<div/>after"
    }
    new PointerAssertion {
      pointer = "/temps"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/type"
      equals = "ROOT"
    }
  }
}
