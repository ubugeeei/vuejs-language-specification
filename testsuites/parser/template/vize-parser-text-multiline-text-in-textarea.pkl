amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-text-multiline-text-in-textarea"
title = "Imported parser input: multiline text in textarea"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/text.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.text"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/text.toml"
  source = "tests/fixtures/parser/text.toml"
  caseName = "multiline text in textarea"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/text.toml"
    cases {
      "multiline text in textarea"
    }
  }
}

input {
  source = #"""
  <textarea>line 1
  line 2</textarea>
  """#
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "<textarea>line 1\nline 2</textarea>",
    "children": [
      {
        "type": "ELEMENT",
        "tag": "textarea",
        "ns": "HTML",
        "tagType": "ELEMENT",
        "props": [],
        "children": [
          {
            "type": "TEXT",
            "content": "line 1 line 2",
            "loc": {
              "start": {
                "column": 11,
                "line": 1,
                "offset": 10
              },
              "end": {
                "column": 7,
                "line": 2,
                "offset": 23
              },
              "source": "line 1\nline 2"
            }
          }
        ],
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 18,
            "line": 2,
            "offset": 34
          },
          "source": "<textarea>line 1\nline 2</textarea>"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 18,
        "line": 2,
        "offset": 34
      },
      "source": "<textarea>line 1\nline 2</textarea>"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/children/0/content"
      equals = "line 1 line 2"
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/end/column"
      equals = 7
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/end/line"
      equals = 2
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/end/offset"
      equals = 23
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/source"
      equals = "line 1\nline 2"
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/start/column"
      equals = 11
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/start/offset"
      equals = 10
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/type"
      equals = "TEXT"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/column"
      equals = 18
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/line"
      equals = 2
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/offset"
      equals = 34
    }
    new PointerAssertion {
      pointer = "/children/0/loc/source"
      equals = "<textarea>line 1\nline 2</textarea>"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/children/0/ns"
      equals = "HTML"
    }
    new PointerAssertion {
      pointer = "/children/0/tag"
      equals = "textarea"
    }
    new PointerAssertion {
      pointer = "/children/0/tagType"
      equals = "ELEMENT"
    }
    new PointerAssertion {
      pointer = "/children/0/type"
      equals = "ELEMENT"
    }
    new PointerAssertion {
      pointer = "/loc/end/column"
      equals = 18
    }
    new PointerAssertion {
      pointer = "/loc/end/line"
      equals = 2
    }
    new PointerAssertion {
      pointer = "/loc/end/offset"
      equals = 34
    }
    new PointerAssertion {
      pointer = "/loc/source"
      equals = "<textarea>line 1\nline 2</textarea>"
    }
    new PointerAssertion {
      pointer = "/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/source"
      equals = "<textarea>line 1\nline 2</textarea>"
    }
    new PointerAssertion {
      pointer = "/temps"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/type"
      equals = "ROOT"
    }
  }
}
