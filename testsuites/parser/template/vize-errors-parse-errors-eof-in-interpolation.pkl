amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-errors-parse-errors-eof-in-interpolation"
title = "Imported parser input: eof in interpolation"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/errors/parse-errors.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.errors"
  "imported.input.parse-errors"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/errors/parse-errors.toml"
  source = "tests/fixtures/errors/parse-errors.toml"
  caseName = "eof in interpolation"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/errors/parse-errors.toml"
    cases {
      "eof in interpolation"
    }
  }
}

input {
  source = "{{ unfinished"
}

expect {
  errorCount = 1
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "{{ unfinished",
    "children": [
      {
        "type": "TEXT",
        "content": "{{ unfinished",
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 14,
            "line": 1,
            "offset": 13
          },
          "source": "{{ unfinished"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 14,
        "line": 1,
        "offset": 13
      },
      "source": "{{ unfinished"
    }
  }
  """#
  normalizedErrors = #"""
  [
    {
      "code": "X_MISSING_INTERPOLATION_END",
      "loc": {
        "start": {
          "column": 1,
          "line": 1,
          "offset": 0
        },
        "end": {
          "column": 1,
          "line": 1,
          "offset": 0
        },
        "source": ""
      }
    }
  ]
  """#
  ast {
    new PointerAssertion {
      pointer = "/children/0/content"
      equals = "{{ unfinished"
