amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-text-text-with-interpolation"
title = "Imported parser input: text with interpolation"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/text.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.text"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/text.toml"
  source = "tests/fixtures/parser/text.toml"
  caseName = "text with interpolation"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/text.toml"
    cases {
      "text with interpolation"
    }
  }
}

input {
  source = "some {{ foo }} text"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "some {{ foo }} text",
    "children": [
      {
        "type": "TEXT",
        "content": "some ",
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 6,
            "line": 1,
            "offset": 5
          },
          "source": "some "
        }
      },
      {
        "type": "INTERPOLATION",
        "content": {
          "type": "SIMPLE_EXPRESSION",
          "loc": {
            "start": {
              "column": 9,
              "line": 1,
              "offset": 8
            },
            "end": {
              "column": 12,
              "line": 1,
              "offset": 11
            },
            "source": "foo"
          },
          "content": "foo",
          "isStatic": false,
          "constType": "NOT_CONSTANT"
        },
        "loc": {
          "start": {
            "column": 6,
            "line": 1,
            "offset": 5
          },
          "end": {
            "column": 15,
            "line": 1,
            "offset": 14
          },
          "source": "{{ foo }}"
        }
      },
      {
        "type": "TEXT",
        "content": " text",
        "loc": {
          "start": {
            "column": 15,
            "line": 1,
            "offset": 14
          },
          "end": {
            "column": 20,
            "line": 1,
            "offset": 19
          },
          "source": " text"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 20,
        "line": 1,
        "offset": 19
      },
      "source": "some {{ foo }} text"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/content"
      equals = "some "
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/column"
      equals = 6
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/line"
