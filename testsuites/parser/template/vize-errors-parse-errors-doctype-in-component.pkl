amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-errors-parse-errors-doctype-in-component"
title = "Imported parser input: DOCTYPE in component"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/errors/parse-errors.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.errors"
  "imported.input.parse-errors"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/errors/parse-errors.toml"
  source = "tests/fixtures/errors/parse-errors.toml"
  caseName = "DOCTYPE in component"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/errors/parse-errors.toml"
    cases {
      "DOCTYPE in component"
    }
  }
}

input {
  source = "<!DOCTYPE html><div></div>"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "<!DOCTYPE html><div></div>",
    "children": [
      {
        "type": "ELEMENT",
        "tag": "div",
        "ns": "HTML",
        "tagType": "ELEMENT",
        "props": [],
        "children": [],
        "loc": {
          "start": {
            "column": 16,
            "line": 1,
            "offset": 15
          },
          "end": {
            "column": 27,
            "line": 1,
            "offset": 26
          },
          "source": "<div></div>"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 27,
        "line": 1,
        "offset": 26
      },
      "source": "<!DOCTYPE html><div></div>"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/loc/end/column"
      equals = 27
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/offset"
      equals = 26
    }
    new PointerAssertion {
      pointer = "/children/0/loc/source"
      equals = "<div></div>"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/column"
      equals = 16
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/offset"
      equals = 15
    }
    new PointerAssertion {
      pointer = "/children/0/ns"
      equals = "HTML"
    }
    new PointerAssertion {
      pointer = "/children/0/tag"
      equals = "div"
    }
    new PointerAssertion {
      pointer = "/children/0/tagType"
      equals = "ELEMENT"
    }
    new PointerAssertion {
      pointer = "/children/0/type"
      equals = "ELEMENT"
    }
    new PointerAssertion {
      pointer = "/loc/end/column"
      equals = 27
    }
    new PointerAssertion {
      pointer = "/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/end/offset"
      equals = 26
    }
    new PointerAssertion {
      pointer = "/loc/source"
      equals = "<!DOCTYPE html><div></div>"
    }
    new PointerAssertion {
      pointer = "/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/source"
      equals = "<!DOCTYPE html><div></div>"
    }
    new PointerAssertion {
      pointer = "/temps"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/type"
      equals = "ROOT"
    }
  }
}
