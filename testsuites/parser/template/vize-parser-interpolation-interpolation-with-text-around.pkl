    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 27,
        "line": 1,
        "offset": 26
      },
      "source": "before {{ message }} after"
    }
  }
  """#
  normalizedErrors = "[]"
