amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-errors-parse-errors-invalid-tag-name-starting-with-digit"
title = "Imported parser input: invalid tag name starting with digit"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/errors/parse-errors.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.errors"
  "imported.input.parse-errors"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/errors/parse-errors.toml"
  source = "tests/fixtures/errors/parse-errors.toml"
  caseName = "invalid tag name starting with digit"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/errors/parse-errors.toml"
    cases {
      "invalid tag name starting with digit"
    }
  }
}

input {
  source = "<1div></1div>"
}

