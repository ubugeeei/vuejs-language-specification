    "type": "ROOT",
    "source": "<template v-slot></template>",
    "children": [
      {
        "type": "ELEMENT",
        "tag": "template",
        "ns": "HTML",
        "tagType": "TEMPLATE",
        "props": [
          {
            "type": "DIRECTIVE",
            "name": "slot",
            "rawName": "v-slot",
            "modifiers": [],
            "loc": {
              "start": {
                "column": 11,
