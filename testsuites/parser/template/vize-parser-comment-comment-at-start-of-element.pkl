amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-comment-comment-at-start-of-element"
title = "Imported parser input: comment at start of element"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/comment.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.comment"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/comment.toml"
  source = "tests/fixtures/parser/comment.toml"
  caseName = "comment at start of element"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/comment.toml"
    cases {
      "comment at start of element"
    }
  }
}

input {
  source = "<div><!-- comment -->text</div>"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "<div><!-- comment -->text</div>",
    "children": [
      {
        "type": "ELEMENT",
        "tag": "div",
        "ns": "HTML",
        "tagType": "ELEMENT",
        "props": [],
        "children": [
          {
            "type": "COMMENT",
            "content": " comment ",
            "loc": {
              "start": {
                "column": 6,
                "line": 1,
                "offset": 5
              },
              "end": {
                "column": 22,
                "line": 1,
                "offset": 21
              },
              "source": "<!-- comment -->"
            }
          },
          {
            "type": "TEXT",
            "content": "text",
            "loc": {
              "start": {
                "column": 22,
                "line": 1,
                "offset": 21
              },
              "end": {
                "column": 26,
                "line": 1,
                "offset": 25
              },
              "source": "text"
            }
          }
        ],
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 32,
            "line": 1,
            "offset": 31
          },
          "source": "<div><!-- comment -->text</div>"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 32,
        "line": 1,
        "offset": 31
      },
      "source": "<div><!-- comment -->text</div>"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/children/0/content"
      equals = " comment "
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/end/column"
      equals = 22
    }
