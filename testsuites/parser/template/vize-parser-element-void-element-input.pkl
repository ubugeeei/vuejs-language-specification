amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-element-void-element-input"
title = "Imported parser input: void element - input"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/element.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.element"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/element.toml"
  source = "tests/fixtures/parser/element.toml"
  caseName = "void element - input"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/element.toml"
    cases {
      "void element - input"
    }
  }
}

input {
  source = "<input>"
}

expect {
  errorCount = 1
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "<input>",
    "children": [
      {
        "type": "ELEMENT",
        "tag": "input",
        "ns": "HTML",
        "tagType": "ELEMENT",
        "props": [],
        "children": [],
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 8,
            "line": 1,
            "offset": 7
          },
          "source": "<input>"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 8,
        "line": 1,
        "offset": 7
      },
      "source": "<input>"
    }
  }
  """#
  normalizedErrors = #"""
  [
    {
      "code": "X_MISSING_END_TAG",
      "loc": {
        "start": {
          "column": 1,
          "line": 1,
          "offset": 0
        },
        "end": {
          "column": 1,
          "line": 1,
          "offset": 0
        },
        "source": ""
      }
    }
  ]
  """#
  ast {
    new PointerAssertion {
      pointer = "/children/0/loc/end/column"
      equals = 8
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/offset"
      equals = 7
    }
    new PointerAssertion {
      pointer = "/children/0/loc/source"
      equals = "<input>"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/children/0/ns"
      equals = "HTML"
    }
    new PointerAssertion {
      pointer = "/children/0/tag"
      equals = "input"
    }
    new PointerAssertion {
      pointer = "/children/0/tagType"
      equals = "ELEMENT"
    }
    new PointerAssertion {
      pointer = "/children/0/type"
      equals = "ELEMENT"
    }
    new PointerAssertion {
      pointer = "/loc/end/column"
      equals = 8
    }
    new PointerAssertion {
      pointer = "/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/end/offset"
      equals = 7
    }
    new PointerAssertion {
      pointer = "/loc/source"
      equals = "<input>"
    }
    new PointerAssertion {
      pointer = "/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/source"
      equals = "<input>"
    }
    new PointerAssertion {
      pointer = "/temps"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/type"
      equals = "ROOT"
    }
  }
  errors {
    new PointerAssertion {
      pointer = "/0/code"
      equals = "X_MISSING_END_TAG"
    }
    new PointerAssertion {
      pointer = "/0/loc/end/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/0/loc/end/offset"
