                "column": 6,
                "line": 1,
                "offset": 5
              },
              "end": {
                "column": 35,
                "line": 1,
                "offset": 34
              },
              "source": "<span><!-- comment --></span>"
            }
          }
        ],
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 41,
            "line": 1,
            "offset": 40
          },
          "source": "<div><span><!-- comment --></span></div>"
        }
