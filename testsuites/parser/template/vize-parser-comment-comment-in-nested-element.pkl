      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 41,
        "line": 1,
        "offset": 40
      },
      "source": "<div><span><!-- comment --></span></div>"
    }
  }
  """#
  normalizedErrors = "[]"
