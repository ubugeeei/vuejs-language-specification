amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-interpolation-interpolation-with-text-after"
title = "Imported parser input: interpolation with text after"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/interpolation.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.interpolation"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/interpolation.toml"
  source = "tests/fixtures/parser/interpolation.toml"
  caseName = "interpolation with text after"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/interpolation.toml"
    cases {
      "interpolation with text after"
    }
  }
}

input {
  source = "{{ message }} text"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "{{ message }} text",
    "children": [
      {
        "type": "INTERPOLATION",
        "content": {
          "type": "SIMPLE_EXPRESSION",
          "loc": {
            "start": {
              "column": 4,
              "line": 1,
              "offset": 3
            },
            "end": {
              "column": 11,
              "line": 1,
              "offset": 10
            },
            "source": "message"
          },
          "content": "message",
          "isStatic": false,
          "constType": "NOT_CONSTANT"
        },
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 14,
            "line": 1,
            "offset": 13
          },
          "source": "{{ message }}"
        }
      },
      {
        "type": "TEXT",
        "content": " text",
        "loc": {
          "start": {
            "column": 14,
            "line": 1,
            "offset": 13
          },
          "end": {
            "column": 19,
            "line": 1,
            "offset": 18
          },
          "source": " text"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 19,
        "line": 1,
        "offset": 18
      },
      "source": "{{ message }} text"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/content/constType"
      equals = "NOT_CONSTANT"
    }
    new PointerAssertion {
      pointer = "/children/0/content/content"
      equals = "message"
    }
    new PointerAssertion {
      pointer = "/children/0/content/isStatic"
      equals = false
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/end/column"
      equals = 11
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/end/offset"
      equals = 10
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/source"
      equals = "message"
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/start/column"
      equals = 4
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/start/offset"
      equals = 3
    }
    new PointerAssertion {
      pointer = "/children/0/content/type"
      equals = "SIMPLE_EXPRESSION"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/column"
      equals = 14
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/offset"
      equals = 13
    }
    new PointerAssertion {
      pointer = "/children/0/loc/source"
      equals = "{{ message }}"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/children/0/type"
      equals = "INTERPOLATION"
    }
    new PointerAssertion {
      pointer = "/children/1/content"
      equals = " text"
    }
    new PointerAssertion {
      pointer = "/children/1/loc/end/column"
      equals = 19
    }
    new PointerAssertion {
      pointer = "/children/1/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/1/loc/end/offset"
      equals = 18
    }
    new PointerAssertion {
      pointer = "/children/1/loc/source"
      equals = " text"
    }
    new PointerAssertion {
      pointer = "/children/1/loc/start/column"
      equals = 14
    }
    new PointerAssertion {
      pointer = "/children/1/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/1/loc/start/offset"
      equals = 13
    }
    new PointerAssertion {
      pointer = "/children/1/type"
      equals = "TEXT"
    }
    new PointerAssertion {
      pointer = "/loc/end/column"
      equals = 19
    }
    new PointerAssertion {
      pointer = "/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/end/offset"
      equals = 18
    }
    new PointerAssertion {
      pointer = "/loc/source"
      equals = "{{ message }} text"
    }
    new PointerAssertion {
      pointer = "/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/source"
      equals = "{{ message }} text"
    }
    new PointerAssertion {
      pointer = "/temps"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/type"
      equals = "ROOT"
    }
  }
}
