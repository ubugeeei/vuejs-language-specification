amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-directive-custom-directive-without-value"
title = "Imported parser input: custom directive without value"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/directive.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.directive"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/directive.toml"
  source = "tests/fixtures/parser/directive.toml"
  caseName = "custom directive without value"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/directive.toml"
    cases {
      "custom directive without value"
    }
  }
}

input {
  source = "<input v-focus>"
}

expect {
  errorCount = 1
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "<input v-focus>",
    "children": [
      {
        "type": "ELEMENT",
        "tag": "input",
        "ns": "HTML",
        "tagType": "ELEMENT",
        "props": [
          {
            "type": "DIRECTIVE",
            "name": "focus",
            "rawName": "v-focus",
            "modifiers": [],
            "loc": {
              "start": {
                "column": 8,
                "line": 1,
                "offset": 7
              },
              "end": {
                "column": 15,
                "line": 1,
                "offset": 14
              },
              "source": "v-focus"
            }
          }
        ],
        "children": [],
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 16,
            "line": 1,
            "offset": 15
          },
          "source": "<input v-focus>"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 16,
        "line": 1,
        "offset": 15
      },
      "source": "<input v-focus>"
    }
  }
  """#
  normalizedErrors = #"""
  [
    {
      "code": "X_MISSING_END_TAG",
      "loc": {
        "start": {
          "column": 1,
          "line": 1,
          "offset": 0
        },
        "end": {
          "column": 1,
          "line": 1,
          "offset": 0
        },
        "source": ""
      }
    }
  ]
  """#
  ast {
    new PointerAssertion {
      pointer = "/children/0/loc/end/column"
      equals = 16
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/offset"
      equals = 15
    }
    new PointerAssertion {
      pointer = "/children/0/loc/source"
      equals = "<input v-focus>"
    }
