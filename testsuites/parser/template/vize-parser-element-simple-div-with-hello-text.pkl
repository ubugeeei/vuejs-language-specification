amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-element-simple-div-with-hello-text"
title = "Imported parser input: simple div with hello text"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/element.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.element"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/element.toml"
  source = "tests/fixtures/parser/element.toml"
  caseName = "simple div with hello text"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/element.toml"
    cases {
      "simple div with hello text"
    }
  }
}

input {
  source = "<div>hello</div>"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "<div>hello</div>",
    "children": [
      {
        "type": "ELEMENT",
        "tag": "div",
        "ns": "HTML",
        "tagType": "ELEMENT",
        "props": [],
        "children": [
          {
            "type": "TEXT",
            "content": "hello",
            "loc": {
              "start": {
                "column": 6,
                "line": 1,
                "offset": 5
              },
              "end": {
                "column": 11,
                "line": 1,
                "offset": 10
              },
              "source": "hello"
            }
          }
        ],
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 17,
            "line": 1,
            "offset": 16
          },
          "source": "<div>hello</div>"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 17,
        "line": 1,
        "offset": 16
      },
      "source": "<div>hello</div>"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/children/0/content"
      equals = "hello"
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/end/column"
      equals = 11
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/end/offset"
      equals = 10
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/source"
      equals = "hello"
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/start/column"
      equals = 6
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/start/offset"
      equals = 5
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/type"
      equals = "TEXT"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/column"
      equals = 17
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/offset"
      equals = 16
    }
    new PointerAssertion {
      pointer = "/children/0/loc/source"
      equals = "<div>hello</div>"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/children/0/ns"
      equals = "HTML"
    }
    new PointerAssertion {
      pointer = "/children/0/tag"
      equals = "div"
    }
    new PointerAssertion {
      pointer = "/children/0/tagType"
      equals = "ELEMENT"
    }
    new PointerAssertion {
      pointer = "/children/0/type"
      equals = "ELEMENT"
    }
    new PointerAssertion {
      pointer = "/loc/end/column"
      equals = 17
    }
    new PointerAssertion {
      pointer = "/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/end/offset"
      equals = 16
    }
    new PointerAssertion {
      pointer = "/loc/source"
      equals = "<div>hello</div>"
    }
    new PointerAssertion {
      pointer = "/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/source"
      equals = "<div>hello</div>"
    }
    new PointerAssertion {
      pointer = "/temps"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/type"
      equals = "ROOT"
    }
  }
}
