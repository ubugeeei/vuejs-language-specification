amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-interpolation-interpolation-with-optional-method-call"
title = "Imported parser input: interpolation with optional method call"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/interpolation.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.interpolation"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/interpolation.toml"
  source = "tests/fixtures/parser/interpolation.toml"
  caseName = "interpolation with optional method call"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/interpolation.toml"
    cases {
      "interpolation with optional method call"
    }
  }
}

input {
  source = "{{ obj?.method?.() }}"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "{{ obj?.method?.() }}",
    "children": [
      {
        "type": "INTERPOLATION",
        "content": {
          "type": "SIMPLE_EXPRESSION",
          "loc": {
            "start": {
              "column": 4,
              "line": 1,
              "offset": 3
            },
            "end": {
              "column": 19,
              "line": 1,
              "offset": 18
            },
            "source": "obj?.method?.()"
          },
          "content": "obj?.method?.()",
          "isStatic": false,
          "constType": "NOT_CONSTANT"
        },
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 22,
            "line": 1,
            "offset": 21
          },
          "source": "{{ obj?.method?.() }}"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 22,
        "line": 1,
        "offset": 21
      },
      "source": "{{ obj?.method?.() }}"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/content/constType"
