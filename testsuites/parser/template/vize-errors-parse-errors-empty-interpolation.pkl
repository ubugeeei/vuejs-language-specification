amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-errors-parse-errors-empty-interpolation"
title = "Imported parser input: empty interpolation"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/errors/parse-errors.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.errors"
  "imported.input.parse-errors"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/errors/parse-errors.toml"
  source = "tests/fixtures/errors/parse-errors.toml"
  caseName = "empty interpolation"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/errors/parse-errors.toml"
    cases {
      "empty interpolation"
    }
  }
}

input {
  source = "{{ }}"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "{{ }}",
    "children": [
      {
        "type": "INTERPOLATION",
        "content": {
          "type": "SIMPLE_EXPRESSION",
          "loc": {
            "start": {
              "column": 4,
              "line": 1,
              "offset": 3
            },
            "end": {
              "column": 3,
              "line": 1,
              "offset": 2
            },
            "source": ""
          },
          "content": "",
          "isStatic": false,
          "constType": "NOT_CONSTANT"
        },
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 6,
            "line": 1,
            "offset": 5
          },
          "source": "{{ }}"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 6,
        "line": 1,
        "offset": 5
      },
      "source": "{{ }}"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/content/constType"
      equals = "NOT_CONSTANT"
    }
    new PointerAssertion {
      pointer = "/children/0/content/content"
      equals = ""
    }
    new PointerAssertion {
      pointer = "/children/0/content/isStatic"
      equals = false
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/end/column"
      equals = 3
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/end/offset"
      equals = 2
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/source"
      equals = ""
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/start/column"
      equals = 4
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/start/offset"
      equals = 3
    }
    new PointerAssertion {
      pointer = "/children/0/content/type"
      equals = "SIMPLE_EXPRESSION"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/column"
      equals = 6
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/offset"
      equals = 5
    }
    new PointerAssertion {
      pointer = "/children/0/loc/source"
      equals = "{{ }}"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/children/0/type"
      equals = "INTERPOLATION"
    }
    new PointerAssertion {
      pointer = "/loc/end/column"
      equals = 6
    }
    new PointerAssertion {
      pointer = "/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/end/offset"
      equals = 5
    }
    new PointerAssertion {
      pointer = "/loc/source"
      equals = "{{ }}"
    }
    new PointerAssertion {
      pointer = "/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/source"
      equals = "{{ }}"
    }
    new PointerAssertion {
      pointer = "/temps"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/type"
      equals = "ROOT"
    }
  }
}
