amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-text-text-before-interpolation"
title = "Imported parser input: text before interpolation"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/text.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.text"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/text.toml"
  source = "tests/fixtures/parser/text.toml"
  caseName = "text before interpolation"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/text.toml"
    cases {
      "text before interpolation"
    }
  }
}

input {
  source = "prefix {{ value }}"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "prefix {{ value }}",
    "children": [
      {
        "type": "TEXT",
        "content": "prefix ",
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 8,
            "line": 1,
            "offset": 7
          },
          "source": "prefix "
        }
      },
      {
        "type": "INTERPOLATION",
        "content": {
          "type": "SIMPLE_EXPRESSION",
          "loc": {
            "start": {
              "column": 11,
              "line": 1,
              "offset": 10
            },
            "end": {
              "column": 16,
              "line": 1,
              "offset": 15
            },
            "source": "value"
          },
          "content": "value",
          "isStatic": false,
          "constType": "NOT_CONSTANT"
        },
        "loc": {
          "start": {
            "column": 8,
            "line": 1,
            "offset": 7
          },
          "end": {
            "column": 19,
            "line": 1,
            "offset": 18
          },
          "source": "{{ value }}"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 19,
        "line": 1,
        "offset": 18
      },
      "source": "prefix {{ value }}"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/content"
      equals = "prefix "
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/column"
      equals = 8
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/offset"
      equals = 7
    }
    new PointerAssertion {
      pointer = "/children/0/loc/source"
      equals = "prefix "
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/children/0/type"
      equals = "TEXT"
    }
    new PointerAssertion {
      pointer = "/children/1/content/constType"
      equals = "NOT_CONSTANT"
    }
    new PointerAssertion {
      pointer = "/children/1/content/content"
      equals = "value"
    }
    new PointerAssertion {
      pointer = "/children/1/content/isStatic"
      equals = false
    }
    new PointerAssertion {
      pointer = "/children/1/content/loc/end/column"
      equals = 16
    }
    new PointerAssertion {
      pointer = "/children/1/content/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/1/content/loc/end/offset"
      equals = 15
    }
    new PointerAssertion {
      pointer = "/children/1/content/loc/source"
      equals = "value"
    }
    new PointerAssertion {
      pointer = "/children/1/content/loc/start/column"
      equals = 11
    }
    new PointerAssertion {
      pointer = "/children/1/content/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/1/content/loc/start/offset"
      equals = 10
    }
    new PointerAssertion {
      pointer = "/children/1/content/type"
      equals = "SIMPLE_EXPRESSION"
    }
    new PointerAssertion {
      pointer = "/children/1/loc/end/column"
      equals = 19
    }
    new PointerAssertion {
      pointer = "/children/1/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/1/loc/end/offset"
      equals = 18
    }
    new PointerAssertion {
      pointer = "/children/1/loc/source"
      equals = "{{ value }}"
    }
    new PointerAssertion {
      pointer = "/children/1/loc/start/column"
      equals = 8
    }
    new PointerAssertion {
      pointer = "/children/1/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/1/loc/start/offset"
      equals = 7
    }
    new PointerAssertion {
      pointer = "/children/1/type"
      equals = "INTERPOLATION"
    }
    new PointerAssertion {
      pointer = "/loc/end/column"
      equals = 19
    }
    new PointerAssertion {
      pointer = "/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/end/offset"
      equals = 18
    }
    new PointerAssertion {
      pointer = "/loc/source"
      equals = "prefix {{ value }}"
    }
    new PointerAssertion {
      pointer = "/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/source"
      equals = "prefix {{ value }}"
    }
    new PointerAssertion {
      pointer = "/temps"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/type"
      equals = "ROOT"
    }
  }
}
