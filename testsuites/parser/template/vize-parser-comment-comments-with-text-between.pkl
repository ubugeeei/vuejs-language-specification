amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-comment-comments-with-text-between"
title = "Imported parser input: comments with text between"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/comment.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.comment"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/comment.toml"
  source = "tests/fixtures/parser/comment.toml"
  caseName = "comments with text between"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/comment.toml"
    cases {
      "comments with text between"
    }
  }
}

input {
  source = "<!--a-->text<!--b-->"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "<!--a-->text<!--b-->",
    "children": [
      {
        "type": "COMMENT",
        "content": "a",
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 9,
            "line": 1,
            "offset": 8
          },
          "source": "<!--a-->"
        }
      },
      {
        "type": "TEXT",
        "content": "text",
        "loc": {
          "start": {
            "column": 9,
            "line": 1,
            "offset": 8
          },
          "end": {
            "column": 13,
            "line": 1,
            "offset": 12
          },
          "source": "text"
        }
      },
      {
        "type": "COMMENT",
        "content": "b",
        "loc": {
          "start": {
            "column": 13,
            "line": 1,
            "offset": 12
          },
          "end": {
            "column": 21,
            "line": 1,
            "offset": 20
          },
          "source": "<!--b-->"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 21,
        "line": 1,
        "offset": 20
      },
      "source": "<!--a-->text<!--b-->"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/content"
      equals = "a"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/column"
      equals = 9
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/offset"
      equals = 8
    }
    new PointerAssertion {
      pointer = "/children/0/loc/source"
      equals = "<!--a-->"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/line"
      equals = 1
