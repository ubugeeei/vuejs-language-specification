amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-text-text-after-interpolation"
title = "Imported parser input: text after interpolation"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/text.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.text"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/text.toml"
  source = "tests/fixtures/parser/text.toml"
  caseName = "text after interpolation"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/text.toml"
    cases {
      "text after interpolation"
    }
  }
}

input {
  source = "{{ value }} suffix"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "{{ value }} suffix",
    "children": [
      {
        "type": "INTERPOLATION",
        "content": {
          "type": "SIMPLE_EXPRESSION",
          "loc": {
            "start": {
              "column": 4,
              "line": 1,
              "offset": 3
            },
            "end": {
              "column": 9,
              "line": 1,
              "offset": 8
            },
            "source": "value"
          },
          "content": "value",
          "isStatic": false,
          "constType": "NOT_CONSTANT"
        },
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 12,
            "line": 1,
            "offset": 11
          },
          "source": "{{ value }}"
        }
      },
      {
        "type": "TEXT",
        "content": " suffix",
        "loc": {
          "start": {
            "column": 12,
            "line": 1,
            "offset": 11
          },
          "end": {
            "column": 19,
            "line": 1,
            "offset": 18
          },
          "source": " suffix"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 19,
        "line": 1,
        "offset": 18
      },
      "source": "{{ value }} suffix"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/content/constType"
      equals = "NOT_CONSTANT"
    }
    new PointerAssertion {
      pointer = "/children/0/content/content"
      equals = "value"
    }
    new PointerAssertion {
      pointer = "/children/0/content/isStatic"
      equals = false
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/end/column"
      equals = 9
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/end/offset"
      equals = 8
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/source"
      equals = "value"
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/start/column"
      equals = 4
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/content/loc/start/offset"
      equals = 3
    }
    new PointerAssertion {
      pointer = "/children/0/content/type"
      equals = "SIMPLE_EXPRESSION"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/column"
      equals = 12
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/offset"
      equals = 11
    }
    new PointerAssertion {
      pointer = "/children/0/loc/source"
      equals = "{{ value }}"
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/children/0/type"
      equals = "INTERPOLATION"
    }
    new PointerAssertion {
      pointer = "/children/1/content"
      equals = " suffix"
    }
    new PointerAssertion {
      pointer = "/children/1/loc/end/column"
      equals = 19
    }
    new PointerAssertion {
      pointer = "/children/1/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/1/loc/end/offset"
      equals = 18
    }
    new PointerAssertion {
      pointer = "/children/1/loc/source"
      equals = " suffix"
    }
    new PointerAssertion {
      pointer = "/children/1/loc/start/column"
      equals = 12
    }
    new PointerAssertion {
      pointer = "/children/1/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/1/loc/start/offset"
      equals = 11
    }
    new PointerAssertion {
      pointer = "/children/1/type"
      equals = "TEXT"
    }
    new PointerAssertion {
      pointer = "/loc/end/column"
      equals = 19
    }
    new PointerAssertion {
      pointer = "/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/end/offset"
      equals = 18
    }
    new PointerAssertion {
      pointer = "/loc/source"
      equals = "{{ value }} suffix"
    }
    new PointerAssertion {
      pointer = "/loc/start/column"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/loc/start/offset"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/source"
      equals = "{{ value }} suffix"
    }
    new PointerAssertion {
      pointer = "/temps"
      equals = 0
    }
    new PointerAssertion {
      pointer = "/type"
      equals = "ROOT"
    }
  }
}
