amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-text-empty-string-between-elements"
title = "Imported parser input: empty string between elements"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/text.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.text"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/text.toml"
  source = "tests/fixtures/parser/text.toml"
  caseName = "empty string between elements"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/text.toml"
    cases {
      "empty string between elements"
    }
  }
}

input {
  source = "<div></div><span></span>"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "<div></div><span></span>",
    "children": [
      {
        "type": "ELEMENT",
        "tag": "div",
        "ns": "HTML",
        "tagType": "ELEMENT",
        "props": [],
        "children": [],
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 12,
            "line": 1,
            "offset": 11
          },
          "source": "<div></div>"
        }
      },
      {
        "type": "ELEMENT",
        "tag": "span",
        "ns": "HTML",
        "tagType": "ELEMENT",
        "props": [],
        "children": [],
        "loc": {
          "start": {
            "column": 12,
            "line": 1,
            "offset": 11
          },
          "end": {
            "column": 25,
            "line": 1,
            "offset": 24
          },
          "source": "<span></span>"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 25,
        "line": 1,
        "offset": 24
      },
      "source": "<div></div><span></span>"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/loc/end/column"
      equals = 12
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/loc/end/offset"
      equals = 11
    }
    new PointerAssertion {
      pointer = "/children/0/loc/source"
