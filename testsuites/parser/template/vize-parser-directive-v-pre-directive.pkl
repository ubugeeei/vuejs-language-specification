amends "../../../schemas/ParserTestSuite.pkl"

id = "parser.template.vize-parser-directive-v-pre-directive"
title = "Imported parser input: v-pre directive"
kind = "template-base-parse"
summary = "Static parser conformance derived from copied input tests/fixtures/parser/directive.toml and the official vuejs/core parser oracle."

features {
  "parser.template"
  "imported.input"
  "imported.input.parser"
  "imported.input.directive"
}

inputOrigin = new ImportedInputOrigin {
  copiedPath = "provenance/vendor/ubugeeei-vize/tests/fixtures/parser/directive.toml"
  source = "tests/fixtures/parser/directive.toml"
  caseName = "v-pre directive"
  originRepository = "ubugeeei/vize"
}

oracle = new ReferenceOracle {
  repository = "vuejs/core"
  moduleName = "@vue/compiler-core"
  operation = "baseParse"
}

upstream {
  new UpstreamReference {
    repository = "ubugeeei/vize"
    source = "tests/fixtures/parser/directive.toml"
    cases {
      "v-pre directive"
    }
  }
}

input {
  source = "<div v-pre>{{ raw }}</div>"
}

expect {
  errorCount = 0
  normalizedAst = #"""
  {
    "type": "ROOT",
    "source": "<div v-pre>{{ raw }}</div>",
    "children": [
      {
        "type": "ELEMENT",
        "tag": "div",
        "ns": "HTML",
        "tagType": "ELEMENT",
        "props": [],
        "children": [
          {
            "type": "TEXT",
            "content": "{{ raw }}",
            "loc": {
              "start": {
                "column": 12,
                "line": 1,
                "offset": 11
              },
              "end": {
                "column": 21,
                "line": 1,
                "offset": 20
              },
              "source": "{{ raw }}"
            }
          }
        ],
        "loc": {
          "start": {
            "column": 1,
            "line": 1,
            "offset": 0
          },
          "end": {
            "column": 27,
            "line": 1,
            "offset": 26
          },
          "source": "<div v-pre>{{ raw }}</div>"
        }
      }
    ],
    "helpers": {},
    "components": [],
    "directives": [],
    "hoists": [],
    "imports": [],
    "cached": [],
    "temps": 0,
    "loc": {
      "start": {
        "column": 1,
        "line": 1,
        "offset": 0
      },
      "end": {
        "column": 27,
        "line": 1,
        "offset": 26
      },
      "source": "<div v-pre>{{ raw }}</div>"
    }
  }
  """#
  normalizedErrors = "[]"
  ast {
    new PointerAssertion {
      pointer = "/children/0/children/0/content"
      equals = "{{ raw }}"
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/end/column"
      equals = 21
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/end/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/end/offset"
      equals = 20
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/source"
      equals = "{{ raw }}"
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/start/column"
      equals = 12
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/start/line"
      equals = 1
    }
    new PointerAssertion {
      pointer = "/children/0/children/0/loc/start/offset"
      equals = 11
    }
    new PointerAssertion {
